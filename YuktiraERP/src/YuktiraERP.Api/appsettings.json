{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "YuktiraDb": ""
  },
  "Jwt": {
    "Secret": "<your-jwt-secret-min-32-chars>",
