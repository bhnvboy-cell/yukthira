  },
  "SMS": {
    "Provider": "Twilio",
    "AccountSid": "",
    "AuthToken": "",
    "FromNumber": "+1234567890"
  },
  "Features": {
    "EnableMFA": false,
    "EnableAudit": true,
    "EnableWorkflow": true,
    "EnablePlugins": true,
    "EnableMrp": true,
    "EnableAI": true
  }
