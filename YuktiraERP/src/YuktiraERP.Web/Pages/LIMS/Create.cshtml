@page
@model YuktiraERP.Web.Pages.LIMS.CreateModel
@{ ViewData["Title"] = "Register Sample"; }
<div class="row justify-content-center"><div class="col-lg-8">
    <div class="card shadow-sm"><div class="card-header bg-primary text-white"><h5 class="mb-0"><i class="bi bi-plus-circle me-2"></i>Register Sample</h5></div>
    <div class="card-body">
        <form method="post">
            <div class="row mb-3">
                <div class="col-md-6"><label asp-for="Sample.MaterialName" class="form-label"></label><input asp-for="Sample.MaterialName" class="form-control" /></div>
                <div class="col-md-3"><label asp-for="Sample.Source" class="form-label"></label><select asp-for="Sample.Source" class="form-select"><option>Incoming</option><option>Production</option><option>Effluent</option><option>Stability</option></select></div>
                <div class="col-md-3"><label asp-for="Sample.Status" class="form-label"></label><select asp-for="Sample.Status" class="form-select"><option>Submitted</option><option>In Progress</option><option>Completed</option><option>On Hold</option></select></div>
            </div>
            <div class="row mb-3">
                <div class="col-md-4"><label asp-for="Sample.CollectionDate" class="form-label"></label><input asp-for="Sample.CollectionDate" class="form-control" type="date" /></div>
                <div class="col-md-3"><label asp-for="Sample.TestCount" class="form-label"></label><input asp-for="Sample.TestCount" class="form-control" /></div>
            </div>
            <div class="d-flex gap-2"><button type="submit" class="btn btn-primary"><i class="bi bi-save me-1"></i>Save</button><a asp-page="/LIMS/Index" class="btn btn-outline-secondary">Cancel</a></div>
        </form>
    </div></div>
</div></div>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }
