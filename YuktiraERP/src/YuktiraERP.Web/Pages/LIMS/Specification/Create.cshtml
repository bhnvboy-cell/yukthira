@page
@model YuktiraERP.Web.Pages.LIMS.Specification.CreateModel
@{ ViewData["Title"] = "New Specification"; }
<div class="row justify-content-center"><div class="col-lg-8">
<div class="card shadow-sm"><div class="card-header bg-primary text-white"><h5 class="mb-0"><i class="bi bi-plus-circle me-2"></i>New Specification</h5></div>
<div class="card-body">
<form method="post">
<div class="row mb-3">
<div class="col-md-4"><label asp-for="Spec.MaterialName" class="form-label"></label><input asp-for="Spec.MaterialName" class="form-control" /><span asp-validation-for="Spec.MaterialName" class="text-danger small"></span></div>
<div class="col-md-4"><label asp-for="Spec.Characteristic" class="form-label"></label><input asp-for="Spec.Characteristic" class="form-control" /></div>
<div class="col-md-4"><label asp-for="Spec.Status" class="form-label"></label><select asp-for="Spec.Status" class="form-select"><option value="Active">Active</option><option value="Inactive">Inactive</option></select></div>
</div>
<div class="row mb-4">
<div class="col-md-4"><label asp-for="Spec.MinValue" class="form-label"></label><input asp-for="Spec.MinValue" class="form-control" /></div>
<div class="col-md-4"><label asp-for="Spec.MaxValue" class="form-label"></label><input asp-for="Spec.MaxValue" class="form-control" /></div>
</div>
<div class="d-flex gap-2"><button type="submit" class="btn btn-primary"><i class="bi bi-save me-1"></i>Save</button><a asp-page="/LIMS/Index" class="btn btn-outline-secondary"><i class="bi bi-x me-1"></i>Cancel</a></div>
</form>
</div></div>
</div></div>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }
