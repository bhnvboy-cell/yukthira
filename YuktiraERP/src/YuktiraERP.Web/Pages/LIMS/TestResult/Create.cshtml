@page
@model YuktiraERP.Web.Pages.LIMS.TestResult.CreateModel
@{ ViewData["Title"] = "Record Test Result"; }
<div class="row justify-content-center"><div class="col-lg-8">
<div class="card shadow-sm"><div class="card-header bg-primary text-white"><h5 class="mb-0"><i class="bi bi-plus-circle me-2"></i>Record Test Result</h5></div>
<div class="card-body">
<form method="post">
<div class="row mb-3">
<div class="col-md-4"><label asp-for="Result.SampleId" class="form-label"></label><input asp-for="Result.SampleId" class="form-control" placeholder="SMP-..." /></div>
<div class="col-md-8"><label asp-for="Result.TestName" class="form-label"></label><input asp-for="Result.TestName" class="form-control" /></div>
</div>
<div class="row mb-3">
<div class="col-md-4"><label asp-for="Result.Result" class="form-label"></label><input asp-for="Result.Result" class="form-control" /></div>
<div class="col-md-4"><label asp-for="Result.Specification" class="form-label"></label><input asp-for="Result.Specification" class="form-control" /></div>
<div class="col-md-4"><label asp-for="Result.Status" class="form-label"></label><select asp-for="Result.Status" class="form-select"><option>Pending</option><option>Passed</option><option>Failed</option></select></div>
</div>
<div class="d-flex gap-2"><button type="submit" class="btn btn-primary"><i class="bi bi-save me-1"></i>Save</button><a asp-page="/LIMS/Index" class="btn btn-outline-secondary">Cancel</a></div>
</form>
</div></div>
</div></div>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }
