@page
@model YuktiraERP.Web.Pages.LIMS.Instrument.CreateModel
@{ ViewData["Title"] = "New Instrument"; }
<div class="row justify-content-center"><div class="col-lg-8">
<div class="card shadow-sm"><div class="card-header bg-primary text-white"><h5 class="mb-0"><i class="bi bi-plus-circle me-2"></i>New Instrument</h5></div>
<div class="card-body">
<form method="post">
<div class="row mb-3">
<div class="col-md-6"><label asp-for="Instrument.Name" class="form-label"></label><input asp-for="Instrument.Name" class="form-control" /><span asp-validation-for="Instrument.Name" class="text-danger small"></span></div>
<div class="col-md-3"><label asp-for="Instrument.Type" class="form-label"></label><select asp-for="Instrument.Type" class="form-select"><option value="Analytical">Analytical</option><option value="Chromatography">Chromatography</option><option value="Weighing">Weighing</option><option value="Spectroscopy">Spectroscopy</option><option value="Other">Other</option></select></div>
<div class="col-md-3"><label asp-for="Instrument.Status" class="form-label"></label><select asp-for="Instrument.Status" class="form-select"><option value="Operational">Operational</option><option value="Under Maintenance">Under Maintenance</option><option value="Retired">Retired</option></select></div>
</div>
<div class="row mb-4">
<div class="col-md-4"><label asp-for="Instrument.LastCalibration" class="form-label"></label><input asp-for="Instrument.LastCalibration" class="form-control" type="date" /></div>
<div class="col-md-4"><label asp-for="Instrument.NextCalibration" class="form-label"></label><input asp-for="Instrument.NextCalibration" class="form-control" type="date" /></div>
</div>
<div class="d-flex gap-2"><button type="submit" class="btn btn-primary"><i class="bi bi-save me-1"></i>Save</button><a asp-page="/LIMS/Index" class="btn btn-outline-secondary"><i class="bi bi-x me-1"></i>Cancel</a></div>
</form>
</div></div>
</div></div>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }
