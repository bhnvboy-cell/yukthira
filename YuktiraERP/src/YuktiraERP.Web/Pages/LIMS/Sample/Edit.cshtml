@page
@model YuktiraERP.Web.Pages.LIMS.Sample.EditModel
@{ ViewData["Title"] = "Edit Sample"; }
<div class="row justify-content-center"><div class="col-lg-8">
<div class="card shadow-sm"><div class="card-header bg-warning text-dark"><h5 class="mb-0"><i class="bi bi-pencil me-2"></i>Edit Sample</h5></div>
<div class="card-body">
<form method="post">
<input type="hidden" asp-for="Sample.Id" />
<div class="row mb-3">
<div class="col-md-6"><label asp-for="Sample.SampleId" class="form-label"></label><input asp-for="Sample.SampleId" class="form-control" /><span asp-validation-for="Sample.SampleId" class="text-danger small"></span></div>
<div class="col-md-6"><label asp-for="Sample.MaterialName" class="form-label"></label><input asp-for="Sample.MaterialName" class="form-control" /><span asp-validation-for="Sample.MaterialName" class="text-danger small"></span></div>
</div>
<div class="row mb-3">
<div class="col-md-6"><label asp-for="Sample.Source" class="form-label"></label><input asp-for="Sample.Source" class="form-control" /><span asp-validation-for="Sample.Source" class="text-danger small"></span></div>
<div class="col-md-6"><label asp-for="Sample.CollectionDate" class="form-label"></label><input asp-for="Sample.CollectionDate" class="form-control" /><span asp-validation-for="Sample.CollectionDate" class="text-danger small"></span></div>
</div>
<div class="row mb-3">
<div class="col-md-6"><label asp-for="Sample.TestCount" class="form-label"></label><input asp-for="Sample.TestCount" class="form-control" /><span asp-validation-for="Sample.TestCount" class="text-danger small"></span></div>
<div class="col-md-6"><label asp-for="Sample.Status" class="form-label"></label><input asp-for="Sample.Status" class="form-control" /><span asp-validation-for="Sample.Status" class="text-danger small"></span></div>
</div>
<div class="d-flex gap-2"><button type="submit" class="btn btn-warning"><i class="bi bi-save me-1"></i>Update</button><a asp-page="/LIMS/Index" class="btn btn-outline-secondary"><i class="bi bi-x me-1"></i>Cancel</a></div>
</form>
</div></div>
</div></div>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }
