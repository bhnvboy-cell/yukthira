@page
@model YuktiraERP.Web.Pages.LIMS.Sample.DisplayModel
@using YuktiraERP.Infrastructure.Data.Entities
@{ ViewData["Title"] = "Sample Details"; }
<div class="row justify-content-center"><div class="col-lg-8">
<div class="card shadow-sm"><div class="card-header bg-info text-white"><h5 class="mb-0"><i class="bi bi-eye me-2"></i>Sample Details</h5></div>
<div class="card-body">
<dl class="row mb-0">
<dt class="col-sm-4">SampleId</dt><dd class="col-sm-8">@Model.Sample.SampleId</dd>
<dt class="col-sm-4">MaterialName</dt><dd class="col-sm-8">@Model.Sample.MaterialName</dd>
<dt class="col-sm-4">Source</dt><dd class="col-sm-8">@Model.Sample.Source</dd>
<dt class="col-sm-4">CollectionDate</dt><dd class="col-sm-8">@Model.Sample.CollectionDate</dd>
<dt class="col-sm-4">TestCount</dt><dd class="col-sm-8">@Model.Sample.TestCount</dd>
<dt class="col-sm-4">Status</dt><dd class="col-sm-8">@Model.Sample.Status</dd>
</dl>
</div>
<div class="card-footer">
<a asp-page="/LIMS/Index" class="btn btn-outline-secondary"><i class="bi bi-arrow-left me-1"></i>Back</a>
<a asp-page="/LIMS/Sample/Edit" asp-route-id="@Model.Sample.Id" class="btn btn-warning"><i class="bi bi-pencil me-1"></i>Edit</a>
</div>
</div></div>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }
