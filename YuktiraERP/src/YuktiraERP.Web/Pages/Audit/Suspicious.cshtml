@page
@model YuktiraERP.Web.Pages.Audit.SuspiciousModel
@using YuktiraERP.Infrastructure.Data.Entities
@{ ViewData["Title"] = "Suspicious Activity (AL02)"; }
<h2><i class="bi bi-exclamation-triangle me-2"></i>Suspicious Activity</h2>
<div class="card mt-3"><div class="card-body">
<table class="table table-hover table-sm table-danger datatable">
<thead><tr><th>Time</th><th>User</th><th>Module</th><th>Action</th><th>Description</th><th>IP</th></tr></thead>
<tbody>
@foreach (var e in Model.Entries)
{
<tr>
<td>@e.Timestamp.ToString("g")</td><td>@e.UserName</td><td>@e.ModuleName</td><td>@e.ActionType</td><td>@e.Description</td><td>@e.IpAddress</td>
</tr>
}
</tbody></table>
</div></div></div>
