@page
@{
    ViewData["Title"] = "Audit Log";
}
<h2><i class="bi bi-journal-text me-2"></i>Audit Log</h2>
<div class="card mt-3">
    <div class="card-body">
        <div class="row mb-3">
            <div class="col"><input type="text" class="form-control form-control-sm" placeholder="Filter by user..." /></div>
            <div class="col"><select class="form-select form-select-sm"><option>All Modules</option></select></div>
            <div class="col"><input type="date" class="form-control form-control-sm" /></div>
            <div class="col"><input type="date" class="form-control form-control-sm" /></div>
            <div class="col"><button class="btn btn-outline-primary btn-sm">Search</button></div>
        </div>
        <div class="table-responsive">
            <table class="table table-sm table-hover">
                <thead><tr><th>Timestamp</th><th>User</th><th>Module</th><th>Action</th><th>Entity</th><th>IP Address</th><th>Suspicious</th></tr></thead>
                <tbody>
                    <tr><td>2024-01-15 10:30:22</td><td>admin</td><td>MM</td><td><span class="badge bg-info">CREATE</span></td><td>PO-2024000123</td><td>192.168.1.100</td><td><i class="bi bi-check-circle text-success"></i></td></tr>
                    <tr><td>2024-01-15 10:25:10</td><td>jdoe</td><td>SD</td><td><span class="badge bg-warning">UPDATE</span></td><td>SO-2024000456</td><td>10.0.0.55</td><td><i class="bi bi-check-circle text-success"></i></td></tr>
                    <tr><td>2024-01-15 09:15:00</td><td>unknown</td><td>AUTH</td><td><span class="badge bg-danger">LOGIN</span></td><td>Failed attempt</td><td>203.0.113.50</td><td><i class="bi bi-exclamation-triangle text-danger"></i></td></tr>
                </tbody>
            </table>
        </div>
    </div>
</div>
