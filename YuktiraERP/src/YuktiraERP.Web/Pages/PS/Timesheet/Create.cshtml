@page
@model YuktiraERP.Web.Pages.PS.Timesheet.CreateModel
@{ ViewData["Title"] = "Create Timesheet Entry"; }
<div class="row justify-content-center"><div class="col-lg-8">
    <div class="card shadow-sm"><div class="card-header bg-primary text-white"><h5 class="mb-0"><i class="bi bi-plus-circle me-2"></i>Create Timesheet Entry</h5></div>
    <div class="card-body">
        <form method="post">
            <div class="row mb-3">
                <div class="col-md-4"><label asp-for="Entry.EmployeeName" class="form-label"></label><input asp-for="Entry.EmployeeName" class="form-control" /></div>
                <div class="col-md-4"><label asp-for="Entry.ProjectCode" class="form-label"></label><input asp-for="Entry.ProjectCode" class="form-control" placeholder="PRJ-001" /></div>
                <div class="col-md-4"><label asp-for="Entry.TaskCode" class="form-label"></label><input asp-for="Entry.TaskCode" class="form-control" placeholder="TASK-001" /></div>
            </div>
            <div class="row mb-3">
                <div class="col-md-3"><label asp-for="Entry.Date" class="form-label"></label><input asp-for="Entry.Date" class="form-control" type="date" /></div>
                <div class="col-md-2"><label asp-for="Entry.Hours" class="form-label"></label><input asp-for="Entry.Hours" class="form-control" type="number" step="0.5" /></div>
                <div class="col-md-7"><label asp-for="Entry.Description" class="form-label"></label><input asp-for="Entry.Description" class="form-control" /></div>
            </div>
            <div class="d-flex gap-2"><button type="submit" class="btn btn-primary"><i class="bi bi-save me-1"></i>Save</button><a asp-page="/PS/Index" class="btn btn-outline-secondary">Cancel</a></div>
        </form>
    </div></div>
</div></div>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }
