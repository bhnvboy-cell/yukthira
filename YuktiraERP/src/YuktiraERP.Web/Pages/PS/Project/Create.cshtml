@page
@model YuktiraERP.Web.Pages.PS.Project.CreateModel
@{ ViewData["Title"] = "Create Project"; }
<div class="row justify-content-center"><div class="col-lg-8">
    <div class="card shadow-sm"><div class="card-header bg-primary text-white"><h5 class="mb-0"><i class="bi bi-plus-circle me-2"></i>Create Project</h5></div>
    <div class="card-body">
        <form method="post">
            <div class="row mb-3">
                <div class="col-md-4"><label asp-for="Project.ProjectCode" class="form-label"></label><input asp-for="Project.ProjectCode" class="form-control" placeholder="PRJ-001" /></div>
                <div class="col-md-4"><label asp-for="Project.Name" class="form-label"></label><input asp-for="Project.Name" class="form-control" /></div>
                <div class="col-md-4"><label asp-for="Project.Manager" class="form-label"></label><input asp-for="Project.Manager" class="form-control" /></div>
            </div>
            <div class="row mb-3">
                <div class="col-md-4"><label asp-for="Project.Department" class="form-label"></label><input asp-for="Project.Department" class="form-control" /></div>
                <div class="col-md-2"><label asp-for="Project.Budget" class="form-label"></label><input asp-for="Project.Budget" class="form-control" type="number" step="0.01" /></div>
                <div class="col-md-2"><label asp-for="Project.StartDate" class="form-label"></label><input asp-for="Project.StartDate" class="form-control" type="date" /></div>
                <div class="col-md-2"><label asp-for="Project.EndDate" class="form-label"></label><input asp-for="Project.EndDate" class="form-control" type="date" /></div>
            </div>
            <div class="d-flex gap-2"><button type="submit" class="btn btn-primary"><i class="bi bi-save me-1"></i>Save</button><a asp-page="/PS/Index" class="btn btn-outline-secondary">Cancel</a></div>
        </form>
    </div></div>
</div></div>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }
