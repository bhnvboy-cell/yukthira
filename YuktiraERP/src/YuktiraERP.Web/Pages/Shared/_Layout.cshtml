<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Yuktira ERP</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" />
    <link rel="stylesheet" href="~/css/yuktira.css" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    <div class="app-layout">
        @if (Context.User?.Identity?.IsAuthenticated == true)
        {
            <nav class="hybrid-sidebar" id="appSidebar">
                <div class="sidebar-header">
                    <i class="bi bi-cpu"></i>
                    <span class="sidebar-text">Yuktira</span>
                </div>

                <div class="sidebar-body">
                    <div class="nav-category sidebar-text">Operations</div>
                    <a href="/MM" class="nav-item" title="Materials Management"><i class="bi bi-boxes"></i><span class="sidebar-text">MM</span></a>
                    <a href="/SD" class="nav-item" title="Sales &amp; Distribution"><i class="bi bi-cart3"></i><span class="sidebar-text">SD</span></a>
                    <a href="/WM" class="nav-item" title="Warehouse Management"><i class="bi bi-house-door"></i><span class="sidebar-text">WM</span></a>
                    <a href="/PP" class="nav-item" title="Production Planning"><i class="bi bi-gear"></i><span class="sidebar-text">PP</span></a>
                    <a href="/QM" class="nav-item" title="Quality Management"><i class="bi bi-clipboard-check"></i><span class="sidebar-text">QM</span></a>
                    <a href="/PM" class="nav-item" title="Plant Maintenance"><i class="bi bi-tools"></i><span class="sidebar-text">PM</span></a>

                    <div class="nav-category sidebar-text">Finance</div>
                    <a href="/FI" class="nav-item" title="Finance"><i class="bi bi-calculator"></i><span class="sidebar-text">FI</span></a>
                    <a href="/CO" class="nav-item" title="Controlling"><i class="bi bi-pie-chart"></i><span class="sidebar-text">CO</span></a>

                    <div class="nav-category sidebar-text">People</div>
                    <a href="/HR" class="nav-item" title="Human Resources"><i class="bi bi-people"></i><span class="sidebar-text">HR</span></a>
                    <a href="/CRM" class="nav-item" title="Customer Relationship"><i class="bi bi-person-lines-fill"></i><span class="sidebar-text">CRM</span></a>

                    <div class="nav-category sidebar-text">Projects &amp; Labs</div>
                    <a href="/PS" class="nav-item" title="Project System"><i class="bi bi-diagram-3"></i><span class="sidebar-text">PS</span></a>
                    <a href="/LIMS" class="nav-item" title="Lab Information Mgmt"><i class="bi bi-flask"></i><span class="sidebar-text">LIMS</span></a>

                    <div class="nav-category sidebar-text">Analytics</div>
                    <a href="/BI" class="nav-item" title="BI Reports"><i class="bi bi-graph-up"></i><span class="sidebar-text">BI</span></a>
                    <a href="/PP/Mrp?tab=forecast" class="nav-item" title="AI Forecasting"><i class="bi bi-cpu"></i><span class="sidebar-text">AI</span></a>

                    <div class="nav-category sidebar-text">System</div>
                    <a href="/Workflow/Designer" class="nav-item" title="Workflows"><i class="bi bi-arrow-repeat"></i><span class="sidebar-text">WF</span></a>
                    <a href="/Approval" class="nav-item" title="Approvals"><i class="bi bi-check2-square"></i><span class="sidebar-text">Apprv</span></a>
                    <a href="/Notifications" class="nav-item" title="Notifications"><i class="bi bi-bell"></i><span class="sidebar-text">Notif</span></a>
                    <a href="/Transactions" class="nav-item" title="Transaction Codes"><i class="bi bi-keyboard"></i><span class="sidebar-text">TCD</span></a>
                    <a href="/TCodeGenerator" class="nav-item" title="T-Code Generator"><i class="bi bi-cpu"></i><span class="sidebar-text">TCG</span></a>
                    <a href="/Audit" class="nav-item" title="Audit Log"><i class="bi bi-journal-text"></i><span class="sidebar-text">Audit</span></a>
                    <a href="/Admin" class="nav-item" title="Administration"><i class="bi bi-gear-wide"></i><span class="sidebar-text">Admin</span></a>
                    <a href="/Customization" class="nav-item" title="Customize"><i class="bi bi-sliders"></i><span class="sidebar-text">Cust</span></a>
                    <a href="/Integration" class="nav-item" title="Integration Hub"><i class="bi bi-hdd-rack"></i><span class="sidebar-text">Int</span></a>
                </div>

                <div class="sidebar-footer">
                    <div class="theme-dots" id="sidebarThemeDots">
                        <button class="theme-btn" data-theme="modern" title="Modern"></button>
                        <button class="theme-btn" data-theme="classic" title="Classic"></button>
                        <button class="theme-btn" data-theme="premium" title="Premium"></button>
                    </div>
                    <div class="sidebar-text" style="display:flex;align-items:center;gap:8px;flex:1;min-width:0">
                        <div class="avatar" style="width:24px;height:24px;border-radius:50%;background:linear-gradient(135deg,var(--accent-light),var(--accent));display:flex;align-items:center;justify-content:center;font-size:9px;font-weight:700;color:#fff;flex-shrink:0">@(Context.User.Identity.Name?.Substring(0,1).ToUpper()??"U")</div>
                        <span style="font-size:12px;color:var(--sidebar-text-hover);white-space:nowrap;overflow:hidden;text-overflow:ellipsis">@Context.User.Identity.Name</span>
                    </div>
                </div>
            </nav>

            <div class="app-main-area">
                <header class="top-bar">
                    <div class="top-bar-center">
                        <div class="top-bar-search">
                            <i class="bi bi-search"></i>
                            <input type="text" id="globalSearch" placeholder="Transaction search... (Ctrl+K)" autocomplete="off">
                            <div id="globalSearchResults" class="search-results" style="display:none"></div>
                        </div>
                    </div>
                    <div class="top-bar-right">
                        <a href="/Notifications" class="top-bar-icon" title="Notifications">
                            <i class="bi bi-bell"></i>
                            <span class="badge bg-danger" id="notifCount" style="display:none">0</span>
                        </a>
                        <a href="/Dashboard" class="top-bar-icon" title="Home"><i class="bi bi-grid-3x3-gap"></i></a>
                        <a href="/Auth/Logout" class="top-bar-icon text-danger" title="Logout"><i class="bi bi-box-arrow-right"></i></a>
                    </div>
                </header>
                <main class="app-main">
                    @RenderBody()
                </main>
            </div>
        }
        else
        {
            <main class="app-main" style="padding:0 !important;min-height:100vh">
                @RenderBody()
            </main>
        }
    </div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://code.jquery.com/jquery-3.7.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sortablejs@1.15.0/Sortable.min.js"></script>
    <script src="~/js/yuktira.js"></script>
    <script>
        // ── Theme engine ──
        (function() {
            var saved = localStorage.getItem('yuktira_theme') || 'modern';
            document.documentElement.setAttribute('data-theme', saved);
            document.querySelectorAll('.theme-btn').forEach(function(btn) {
                if (btn.getAttribute('data-theme') === saved) btn.style.borderColor = '#fff';
                btn.addEventListener('click', function() {
                    var theme = this.getAttribute('data-theme');
                    document.documentElement.setAttribute('data-theme', theme);
                    localStorage.setItem('yuktira_theme', theme);
                    document.querySelectorAll('.theme-btn').forEach(function(b) { b.style.borderColor = 'transparent'; });
                    this.style.borderColor = '#fff';
                });
            });
        })();

        // ── Sidebar active link ──
        (function() {
            var path = window.location.pathname;
            document.querySelectorAll('.nav-item').forEach(function(el) {
                var href = el.getAttribute('href');
                if (href && (path === href || path.startsWith(href + '/'))) {
                    el.classList.add('active');
                }
            });
        })();

        // ── Notification badge ──
        (function() {
            var badge = document.getElementById('notifCount');
            if (badge) {
                fetch('/api/notifications/unread-count').then(function(r) { return r.json(); }).then(function(d) {
                    if (d.count > 0) {
                        badge.textContent = d.count > 99 ? '99+' : d.count;
                        badge.style.display = '';
                    }
                });
            }
        })();

        // ── Global search (Ctrl+K) ──
        var searchTimeout;
        $('#globalSearch').on('input', function() {
            clearTimeout(searchTimeout);
            var val = $(this).val().trim().toUpperCase();
            var results = $('#globalSearchResults');
            if (val.length < 2) { results.hide(); return; }
            searchTimeout = setTimeout(function() {
                $.get('/api/transaction/search?q=' + encodeURIComponent(val), function(data) {
                    var html = '';
                    data.forEach(function(t) {
                        html += '<button type="button" class="list-group-item list-group-item-action d-flex align-items-center gap-2 py-2" onclick="window.location.href=\'' + t.route + '\'">';
                        html += '<i class="bi ' + t.icon + ' text-primary"></i>';
                        html += '<div class="small"><strong>' + t.code + '</strong> <span class="text-muted">- ' + t.name + '</span></div>';
                        html += '</button>';
                    });
                    if (!data.length) html = '<div class="list-group-item text-muted small">No matches found</div>';
                    results.html(html).show();
                });
            }, 150);
        });

        $(document).on('keydown', function(e) {
            if ((e.ctrlKey || e.metaKey) && e.key === 'k') { e.preventDefault(); $('#globalSearch').focus(); }
            if (e.key === 'Escape') { $('#globalSearch').val(''); $('#globalSearchResults').hide(); }
        });

        $(document).on('click', function(e) {
            if (!$(e.target).closest('.top-bar-search').length) $('#globalSearchResults').hide();
        });

        $('#globalSearch').on('keydown', function(e) {
            if (e.key === 'Enter') {
                var first = $('#globalSearchResults button:first');
                if (first.length) {
                    var m = first.attr('onclick').match(/'([^']+)'/);
                    if (m) window.location.href = m[1];
                }
            }
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
