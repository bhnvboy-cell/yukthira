@page
@model YuktiraERP.Web.Pages.CO.CostCenter.EditModel
@{ ViewData["Title"] = "Edit Cost Center"; }
<div class="row justify-content-center"><div class="col-lg-8">
<div class="card shadow-sm"><div class="card-header bg-warning text-dark"><h5 class="mb-0"><i class="bi bi-pencil me-2"></i>Edit Cost Center</h5></div>
<div class="card-body">
<form method="post">
<input type="hidden" asp-for="CostCenter.Id" />
<div class="row mb-3">
<div class="col-md-6"><label asp-for="CostCenter.Code" class="form-label"></label><input asp-for="CostCenter.Code" class="form-control" /><span asp-validation-for="CostCenter.Code" class="text-danger small"></span></div>
<div class="col-md-6"><label asp-for="CostCenter.Name" class="form-label"></label><input asp-for="CostCenter.Name" class="form-control" /><span asp-validation-for="CostCenter.Name" class="text-danger small"></span></div>
</div>
<div class="row mb-3">
<div class="col-md-6"><label asp-for="CostCenter.Manager" class="form-label"></label><input asp-for="CostCenter.Manager" class="form-control" /><span asp-validation-for="CostCenter.Manager" class="text-danger small"></span></div>
<div class="col-md-6"><label asp-for="CostCenter.Department" class="form-label"></label><input asp-for="CostCenter.Department" class="form-control" /><span asp-validation-for="CostCenter.Department" class="text-danger small"></span></div>
</div>
<div class="row mb-3">
<div class="col-md-6"><label asp-for="CostCenter.PlannedBudget" class="form-label"></label><input asp-for="CostCenter.PlannedBudget" class="form-control" /><span asp-validation-for="CostCenter.PlannedBudget" class="text-danger small"></span></div>
<div class="col-md-6"><label asp-for="CostCenter.Status" class="form-label"></label><input asp-for="CostCenter.Status" class="form-control" /><span asp-validation-for="CostCenter.Status" class="text-danger small"></span></div>
</div>
<div class="d-flex gap-2"><button type="submit" class="btn btn-warning"><i class="bi bi-save me-1"></i>Update</button><a asp-page="/CO/Index" class="btn btn-outline-secondary"><i class="bi bi-x me-1"></i>Cancel</a></div>
</form>
</div></div>
</div></div>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }
