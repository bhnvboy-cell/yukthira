@page
@model YuktiraERP.Web.Pages.CO.CostCenter.DisplayModel
@using YuktiraERP.Infrastructure.Data.Entities
@{ ViewData["Title"] = "Cost Center Details"; }
<div class="row justify-content-center"><div class="col-lg-8">
<div class="card shadow-sm"><div class="card-header bg-info text-white"><h5 class="mb-0"><i class="bi bi-eye me-2"></i>Cost Center Details</h5></div>
<div class="card-body">
<dl class="row mb-0">
<dt class="col-sm-4">Code</dt><dd class="col-sm-8">@Model.CostCenter.Code</dd>
<dt class="col-sm-4">Name</dt><dd class="col-sm-8">@Model.CostCenter.Name</dd>
<dt class="col-sm-4">Manager</dt><dd class="col-sm-8">@Model.CostCenter.Manager</dd>
<dt class="col-sm-4">Department</dt><dd class="col-sm-8">@Model.CostCenter.Department</dd>
<dt class="col-sm-4">PlannedBudget</dt><dd class="col-sm-8">@Model.CostCenter.PlannedBudget</dd>
<dt class="col-sm-4">Status</dt><dd class="col-sm-8">@Model.CostCenter.Status</dd>
</dl>
</div>
<div class="card-footer">
<a asp-page="/CO/Index" class="btn btn-outline-secondary"><i class="bi bi-arrow-left me-1"></i>Back</a>
<a asp-page="/CO/CostCenter/Edit" asp-route-id="@Model.CostCenter.Id" class="btn btn-warning"><i class="bi bi-pencil me-1"></i>Edit</a>
</div>
</div></div>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }
