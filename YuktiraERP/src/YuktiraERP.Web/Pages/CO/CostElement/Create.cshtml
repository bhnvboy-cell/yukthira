@page
@model YuktiraERP.Web.Pages.CO.CostElement.CreateModel
@{ ViewData["Title"] = "Create Cost Element"; }
<div class="row justify-content-center"><div class="col-lg-8">
    <div class="card shadow-sm"><div class="card-header bg-primary text-white"><h5 class="mb-0"><i class="bi bi-plus-circle me-2"></i>Create Cost Element</h5></div>
    <div class="card-body">
        <form method="post">
            <div class="row mb-3">
                <div class="col-md-4"><label asp-for="Element.Code" class="form-label"></label><input asp-for="Element.Code" class="form-control" placeholder="CE-5000" /></div>
                <div class="col-md-4"><label asp-for="Element.Name" class="form-label"></label><input asp-for="Element.Name" class="form-control" /></div>
            </div>
            <div class="row mb-3">
                <div class="col-md-4"><label asp-for="Element.Type" class="form-label"></label><select asp-for="Element.Type" class="form-select"><option>Primary</option><option>Secondary</option></select></div>
                <div class="col-md-4"><label asp-for="Element.Category" class="form-label"></label><select asp-for="Element.Category" class="form-select"><option>Material</option><option>Labor</option><option>Overhead</option><option>Administrative</option></select></div>
            </div>
            <div class="d-flex gap-2"><button type="submit" class="btn btn-primary"><i class="bi bi-save me-1"></i>Save</button><a asp-page="/CO/Index" class="btn btn-outline-secondary">Cancel</a></div>
        </form>
    </div></div>
</div></div>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }
