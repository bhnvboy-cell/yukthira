@page
@model YuktiraERP.Web.Pages.Workflow.InstancesModel
@{ ViewData["Title"] = "Workflow Instances (WF02)"; }
<h2><i class="bi bi-diagram-3 me-2"></i>Workflow Instances</h2>
<div class="card mt-3"><div class="card-body">
<table class="table table-hover table-sm">
<thead><tr><th>ID</th><th>Name</th><th>Status</th><th>Started</th></tr></thead>
<tbody>
@foreach (var wf in Model.Instances)
{
<tr>
<td>@wf.Id</td><td>@wf.Name</td>
<td><span class="badge bg-@(wf.Status=="Running"?"primary":wf.Status=="Completed"?"success":"warning")">@wf.Status</span></td>
<td>@wf.Started.ToString("g")</td>
</tr>
}
</tbody></table>
</div></div></div>
