@page
@model YuktiraERP.Web.Pages.PP.BOM.EditModel
@{ ViewData["Title"] = "Edit Bill of Material"; }
<div class="row justify-content-center"><div class="col-lg-8">
<div class="card shadow-sm"><div class="card-header bg-warning text-dark"><h5 class="mb-0"><i class="bi bi-pencil me-2"></i>Edit Bill of Material</h5></div>
<div class="card-body">
<form method="post">
<input type="hidden" asp-for="Bom.Id" />
<div class="row mb-3">
<div class="col-md-6"><label asp-for="Bom.BomId" class="form-label"></label><input asp-for="Bom.BomId" class="form-control" /><span asp-validation-for="Bom.BomId" class="text-danger small"></span></div>
<div class="col-md-6"><label asp-for="Bom.ProductName" class="form-label"></label><input asp-for="Bom.ProductName" class="form-control" /><span asp-validation-for="Bom.ProductName" class="text-danger small"></span></div>
</div>
<div class="row mb-3">
<div class="col-md-6"><label asp-for="Bom.ComponentName" class="form-label"></label><input asp-for="Bom.ComponentName" class="form-control" /><span asp-validation-for="Bom.ComponentName" class="text-danger small"></span></div>
<div class="col-md-6"><label asp-for="Bom.Quantity" class="form-label"></label><input asp-for="Bom.Quantity" class="form-control" /><span asp-validation-for="Bom.Quantity" class="text-danger small"></span></div>
</div>
<div class="row mb-3">
<div class="col-md-6"><label asp-for="Bom.UOM" class="form-label"></label><input asp-for="Bom.UOM" class="form-control" /><span asp-validation-for="Bom.UOM" class="text-danger small"></span></div>
<div class="col-md-6"><label asp-for="Bom.Status" class="form-label"></label><input asp-for="Bom.Status" class="form-control" /><span asp-validation-for="Bom.Status" class="text-danger small"></span></div>
</div>
<div class="d-flex gap-2"><button type="submit" class="btn btn-warning"><i class="bi bi-save me-1"></i>Update</button><a asp-page="/PP/Index" class="btn btn-outline-secondary"><i class="bi bi-x me-1"></i>Cancel</a></div>
</form>
</div></div>
</div></div>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }
