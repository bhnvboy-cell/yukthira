@page
@model YuktiraERP.Web.Pages.PP.Routing.CreateModel
@{ ViewData["Title"] = "Create Production Routing"; }
<div class="row justify-content-center"><div class="col-lg-8">
<div class="card shadow-sm"><div class="card-header bg-primary text-white"><h5 class="mb-0"><i class="bi bi-plus-circle me-2"></i>Create Production Routing</h5></div>
<div class="card-body">
<form method="post">
<div class="row mb-3">
<div class="col-md-6"><label asp-for="Routing.ProductName" class="form-label"></label><input asp-for="Routing.ProductName" class="form-control" /></div>
<div class="col-md-3"><label asp-for="Routing.OperationNo" class="form-label"></label><input asp-for="Routing.OperationNo" class="form-control" /></div>
<div class="col-md-3"><label asp-for="Routing.WorkCenter" class="form-label"></label><input asp-for="Routing.WorkCenter" class="form-control" /></div>
</div>
<div class="row mb-3">
<div class="col-md-3"><label asp-for="Routing.SetupTimeHrs" class="form-label"></label><input asp-for="Routing.SetupTimeHrs" class="form-control" /></div>
<div class="col-md-3"><label asp-for="Routing.RunTimeHrs" class="form-label"></label><input asp-for="Routing.RunTimeHrs" class="form-control" /></div>
<div class="col-md-3"><label asp-for="Routing.Status" class="form-label"></label><select asp-for="Routing.Status" class="form-select"><option>Active</option><option>Inactive</option></select></div>
</div>
<div class="d-flex gap-2"><button type="submit" class="btn btn-primary"><i class="bi bi-save me-1"></i>Save</button><a asp-page="/PP/Index" class="btn btn-outline-secondary">Cancel</a></div>
</form>
</div></div>
</div></div>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }
