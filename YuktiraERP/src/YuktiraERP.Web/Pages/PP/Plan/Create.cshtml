@page
@model YuktiraERP.Web.Pages.PP.Plan.CreateModel
@{ ViewData["Title"] = "Create Production Plan"; }
<div class="row justify-content-center"><div class="col-lg-8">
<div class="card shadow-sm"><div class="card-header bg-primary text-white"><h5 class="mb-0"><i class="bi bi-plus-circle me-2"></i>Create Production Plan</h5></div>
<div class="card-body">
<form method="post">
<div class="row mb-3">
<div class="col-md-6"><label asp-for="Plan.ProductName" class="form-label"></label><input asp-for="Plan.ProductName" class="form-control" /><span asp-validation-for="Plan.ProductName" class="text-danger small"></span></div>
<div class="col-md-3"><label asp-for="Plan.Quantity" class="form-label"></label><input asp-for="Plan.Quantity" class="form-control" /></div>
<div class="col-md-3"><label asp-for="Plan.Status" class="form-label"></label><select asp-for="Plan.Status" class="form-select"><option>Planned</option><option>Released</option><option>In Progress</option><option>Completed</option></select></div>
</div>
<div class="row mb-3">
<div class="col-md-6"><label asp-for="Plan.StartDate" class="form-label"></label><input asp-for="Plan.StartDate" class="form-control" type="date" /></div>
<div class="col-md-6"><label asp-for="Plan.EndDate" class="form-label"></label><input asp-for="Plan.EndDate" class="form-control" type="date" /></div>
</div>
<div class="d-flex gap-2"><button type="submit" class="btn btn-primary"><i class="bi bi-save me-1"></i>Save</button><a asp-page="/PP/Index" class="btn btn-outline-secondary">Cancel</a></div>
</form>
</div></div>
</div></div>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }
