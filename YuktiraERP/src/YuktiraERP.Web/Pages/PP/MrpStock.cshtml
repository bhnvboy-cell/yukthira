@page
@model YuktiraERP.Web.Pages.PP.MrpStockModel
@using YuktiraERP.Infrastructure.Data.Entities
@{ ViewData["Title"] = "MRP Stock/Requirements (MD04)"; }
<h2><i class="bi bi-clipboard-data me-2"></i>MRP Stock / Requirements</h2>
<div class="card mt-3"><div class="card-body">
<div class="table-responsive">
<table class="table table-hover table-sm">
<thead><tr><th>Plan ID</th><th>Product</th><th>Quantity</th><th>Start</th><th>End</th><th>Status</th></tr></thead>
<tbody>
@foreach (var p in Model.Plans)
{
<tr>
<td>@p.PlanId</td><td>@p.ProductName</td><td>@p.Quantity</td>
<td>@p.StartDate.ToString("d")</td><td>@p.EndDate.ToString("d")</td>
<td><span class="badge bg-info">@p.Status</span></td>
</tr>
}
</tbody></table>
</div></div></div>
