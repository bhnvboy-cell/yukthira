@page
@model YuktiraERP.Web.Pages.PP.ProductionOrder.DisplayModel
@using YuktiraERP.Infrastructure.Data.Entities
@{ ViewData["Title"] = "Production Order Details"; }
<div class="row justify-content-center"><div class="col-lg-8">
<div class="card shadow-sm"><div class="card-header bg-info text-white"><h5 class="mb-0"><i class="bi bi-eye me-2"></i>Production Order Details</h5></div>
<div class="card-body">
<dl class="row mb-0">
<dt class="col-sm-4">OrderNumber</dt><dd class="col-sm-8">@Model.ProdOrder.OrderNumber</dd>
<dt class="col-sm-4">ProductName</dt><dd class="col-sm-8">@Model.ProdOrder.ProductName</dd>
<dt class="col-sm-4">Quantity</dt><dd class="col-sm-8">@Model.ProdOrder.Quantity</dd>
<dt class="col-sm-4">StartDate</dt><dd class="col-sm-8">@Model.ProdOrder.StartDate</dd>
<dt class="col-sm-4">EndDate</dt><dd class="col-sm-8">@Model.ProdOrder.EndDate</dd>
<dt class="col-sm-4">Status</dt><dd class="col-sm-8">@Model.ProdOrder.Status</dd>
</dl>
</div>
<div class="card-footer">
<a asp-page="/PP/Index" class="btn btn-outline-secondary"><i class="bi bi-arrow-left me-1"></i>Back</a>
<a asp-page="/PP/ProductionOrder/Edit" asp-route-id="@Model.ProdOrder.Id" class="btn btn-warning"><i class="bi bi-pencil me-1"></i>Edit</a>
</div>
</div></div>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }
