@page
@model YuktiraERP.Web.Pages.PP.WorkCenter.CreateModel
@{ ViewData["Title"] = "New Work Center"; }
<div class="row justify-content-center"><div class="col-lg-8">
<div class="card shadow-sm"><div class="card-header bg-primary text-white"><h5 class="mb-0"><i class="bi bi-plus-circle me-2"></i>New Work Center</h5></div>
<div class="card-body">
<form method="post">
<div class="row mb-3">
<div class="col-md-6"><label asp-for="WorkCenter.Name" class="form-label"></label><input asp-for="WorkCenter.Name" class="form-control" /><span asp-validation-for="WorkCenter.Name" class="text-danger small"></span></div>
<div class="col-md-3"><label asp-for="WorkCenter.Department" class="form-label"></label><input asp-for="WorkCenter.Department" class="form-control" /></div>
<div class="col-md-3"><label asp-for="WorkCenter.Status" class="form-label"></label><select asp-for="WorkCenter.Status" class="form-select"><option value="Active">Active</option><option value="Maintenance">Maintenance</option><option value="Inactive">Inactive</option></select></div>
</div>
<div class="row mb-4">
<div class="col-md-4"><label asp-for="WorkCenter.CapacityPerShift" class="form-label"></label><input asp-for="WorkCenter.CapacityPerShift" class="form-control" min="0" step="1" /><span asp-validation-for="WorkCenter.CapacityPerShift" class="text-danger small"></span></div>
</div>
<div class="d-flex gap-2"><button type="submit" class="btn btn-primary"><i class="bi bi-save me-1"></i>Save</button><a asp-page="/PP/Index" class="btn btn-outline-secondary"><i class="bi bi-x me-1"></i>Cancel</a></div>
</form>
</div></div>
</div></div>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }
