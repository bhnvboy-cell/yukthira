@page
@model YuktiraERP.Web.Pages.QM.InspectionPlan.CreateModel
@{ ViewData["Title"] = "Create Inspection Plan"; }
<div class="row justify-content-center"><div class="col-lg-8">
<div class="card shadow-sm"><div class="card-header bg-primary text-white"><h5 class="mb-0"><i class="bi bi-plus-circle me-2"></i>Create Inspection Plan</h5></div>
<div class="card-body">
<form method="post">
<div class="row mb-3">
<div class="col-md-6"><label asp-for="Plan.MaterialName" class="form-label"></label><input asp-for="Plan.MaterialName" class="form-control" /></div>
<div class="col-md-6"><label asp-for="Plan.Characteristic" class="form-label"></label><input asp-for="Plan.Characteristic" class="form-control" /></div>
</div>
<div class="row mb-3">
<div class="col-md-4"><label asp-for="Plan.Method" class="form-label"></label><input asp-for="Plan.Method" class="form-control" /></div>
<div class="col-md-4"><label asp-for="Plan.Frequency" class="form-label"></label><select asp-for="Plan.Frequency" class="form-select"><option>Each Lot</option><option>Every Nth Lot</option><option>Daily</option><option>Weekly</option></select></div>
<div class="col-md-4"><label asp-for="Plan.Status" class="form-label"></label><select asp-for="Plan.Status" class="form-select"><option>Active</option><option>Inactive</option></select></div>
</div>
<div class="d-flex gap-2"><button type="submit" class="btn btn-primary"><i class="bi bi-save me-1"></i>Save</button><a asp-page="/QM/Index" class="btn btn-outline-secondary">Cancel</a></div>
</form>
</div></div>
</div></div>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }
