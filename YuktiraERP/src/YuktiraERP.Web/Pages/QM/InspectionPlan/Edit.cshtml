@page
@model YuktiraERP.Web.Pages.QM.InspectionPlan.EditModel
@{ ViewData["Title"] = "Edit Inspection Plan"; }
<div class="row justify-content-center"><div class="col-lg-8">
<div class="card shadow-sm"><div class="card-header bg-warning text-dark"><h5 class="mb-0"><i class="bi bi-pencil me-2"></i>Edit Inspection Plan</h5></div>
<div class="card-body">
<form method="post">
<input type="hidden" asp-for="Plan.Id" />
<div class="row mb-3">
<div class="col-md-6"><label asp-for="Plan.PlanId" class="form-label"></label><input asp-for="Plan.PlanId" class="form-control" /><span asp-validation-for="Plan.PlanId" class="text-danger small"></span></div>
<div class="col-md-6"><label asp-for="Plan.MaterialName" class="form-label"></label><input asp-for="Plan.MaterialName" class="form-control" /><span asp-validation-for="Plan.MaterialName" class="text-danger small"></span></div>
</div>
<div class="row mb-3">
<div class="col-md-6"><label asp-for="Plan.Characteristic" class="form-label"></label><input asp-for="Plan.Characteristic" class="form-control" /><span asp-validation-for="Plan.Characteristic" class="text-danger small"></span></div>
<div class="col-md-6"><label asp-for="Plan.Method" class="form-label"></label><input asp-for="Plan.Method" class="form-control" /><span asp-validation-for="Plan.Method" class="text-danger small"></span></div>
</div>
<div class="row mb-3">
<div class="col-md-6"><label asp-for="Plan.Frequency" class="form-label"></label><input asp-for="Plan.Frequency" class="form-control" /><span asp-validation-for="Plan.Frequency" class="text-danger small"></span></div>
<div class="col-md-6"><label asp-for="Plan.Status" class="form-label"></label><input asp-for="Plan.Status" class="form-control" /><span asp-validation-for="Plan.Status" class="text-danger small"></span></div>
</div>
<div class="d-flex gap-2"><button type="submit" class="btn btn-warning"><i class="bi bi-save me-1"></i>Update</button><a asp-page="/QM/Index" class="btn btn-outline-secondary"><i class="bi bi-x me-1"></i>Cancel</a></div>
</form>
</div></div>
</div></div>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }
