@page
@model YuktiraERP.Web.Pages.QM.InspectionLot.CreateModel
@{ ViewData["Title"] = "Create Inspection Lot"; }
<div class="row justify-content-center"><div class="col-lg-8">
<div class="card shadow-sm"><div class="card-header bg-primary text-white"><h5 class="mb-0"><i class="bi bi-plus-circle me-2"></i>Create Inspection Lot</h5></div>
<div class="card-body">
<form method="post">
<div class="row mb-3">
<div class="col-md-6"><label asp-for="Lot.MaterialName" class="form-label"></label><input asp-for="Lot.MaterialName" class="form-control" /></div>
<div class="col-md-3"><label asp-for="Lot.Quantity" class="form-label"></label><input asp-for="Lot.Quantity" class="form-control" /></div>
<div class="col-md-3"><label asp-for="Lot.Status" class="form-label"></label><select asp-for="Lot.Status" class="form-select"><option>Pending</option><option>In Progress</option><option>Accepted</option><option>Rejected</option></select></div>
</div>
<div class="d-flex gap-2"><button type="submit" class="btn btn-primary"><i class="bi bi-save me-1"></i>Save</button><a asp-page="/QM/Index" class="btn btn-outline-secondary">Cancel</a></div>
</form>
</div></div>
</div></div>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }
