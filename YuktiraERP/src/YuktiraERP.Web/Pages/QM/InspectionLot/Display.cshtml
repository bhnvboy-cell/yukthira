@page
@model YuktiraERP.Web.Pages.QM.InspectionLot.DisplayModel
@using YuktiraERP.Infrastructure.Data.Entities
@{ ViewData["Title"] = "Inspection Lot Details"; }
<div class="row justify-content-center"><div class="col-lg-8">
<div class="card shadow-sm"><div class="card-header bg-info text-white"><h5 class="mb-0"><i class="bi bi-eye me-2"></i>Inspection Lot Details</h5></div>
<div class="card-body">
<dl class="row mb-0">
<dt class="col-sm-4">LotNumber</dt><dd class="col-sm-8">@Model.Lot.LotNumber</dd>
<dt class="col-sm-4">MaterialName</dt><dd class="col-sm-8">@Model.Lot.MaterialName</dd>
<dt class="col-sm-4">Quantity</dt><dd class="col-sm-8">@Model.Lot.Quantity</dd>
<dt class="col-sm-4">Inspected</dt><dd class="col-sm-8">@Model.Lot.Inspected</dd>
<dt class="col-sm-4">Passed</dt><dd class="col-sm-8">@Model.Lot.Passed</dd>
<dt class="col-sm-4">Failed</dt><dd class="col-sm-8">@Model.Lot.Failed</dd>
<dt class="col-sm-4">Status</dt><dd class="col-sm-8">@Model.Lot.Status</dd>
</dl>
</div>
<div class="card-footer">
<a asp-page="/QM/Index" class="btn btn-outline-secondary"><i class="bi bi-arrow-left me-1"></i>Back</a>
<a asp-page="/QM/InspectionLot/Edit" asp-route-id="@Model.Lot.Id" class="btn btn-warning"><i class="bi bi-pencil me-1"></i>Edit</a>
</div>
</div></div>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }
