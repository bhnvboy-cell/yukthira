@page
@model YuktiraERP.Web.Pages.QM.UsageDecision.CreateModel
@{ ViewData["Title"] = "Usage Decision"; }
<div class="row justify-content-center"><div class="col-lg-8">
<div class="card shadow-sm"><div class="card-header bg-primary text-white"><h5 class="mb-0"><i class="bi bi-plus-circle me-2"></i>Usage Decision</h5></div>
<div class="card-body">
<form method="post">
<div class="row mb-3">
<div class="col-md-4"><label asp-for="Decision.LotNumber" class="form-label"></label><input asp-for="Decision.LotNumber" class="form-control" placeholder="IQ-2024-..." /><span asp-validation-for="Decision.LotNumber" class="text-danger small"></span></div>
<div class="col-md-4"><label asp-for="Decision.MaterialName" class="form-label"></label><input asp-for="Decision.MaterialName" class="form-control" /><span asp-validation-for="Decision.MaterialName" class="text-danger small"></span></div>
<div class="col-md-4"><label asp-for="Decision.DecisionDate" class="form-label"></label><input asp-for="Decision.DecisionDate" class="form-control" type="date" /></div>
</div>
<div class="row mb-3">
<div class="col-md-8"><label asp-for="Decision.Decision" class="form-label"></label><input asp-for="Decision.Decision" class="form-control" /><span asp-validation-for="Decision.Decision" class="text-danger small"></span></div>
</div>
<div class="mb-4"><label asp-for="Decision.Notes" class="form-label"></label><textarea asp-for="Decision.Notes" class="form-control" rows="2"></textarea></div>
<div class="d-flex gap-2"><button type="submit" class="btn btn-primary"><i class="bi bi-save me-1"></i>Save</button><a asp-page="/QM/Index" class="btn btn-outline-secondary"><i class="bi bi-x me-1"></i>Cancel</a></div>
</form>
</div></div>
</div></div>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }
