@page
@model YuktiraERP.Web.Pages.QM.InspectionResult.CreateModel
@{ ViewData["Title"] = "New Inspection Result"; }
<div class="row justify-content-center"><div class="col-lg-8">
<div class="card shadow-sm"><div class="card-header bg-primary text-white"><h5 class="mb-0"><i class="bi bi-plus-circle me-2"></i>New Inspection Result</h5></div>
<div class="card-body">
<form method="post">
<div class="row mb-3">
<div class="col-md-4"><label asp-for="Result.LotNumber" class="form-label"></label><input asp-for="Result.LotNumber" class="form-control" placeholder="IQ-2024-..." /><span asp-validation-for="Result.LotNumber" class="text-danger small"></span></div>
<div class="col-md-4"><label asp-for="Result.Characteristic" class="form-label"></label><input asp-for="Result.Characteristic" class="form-control" /></div>
<div class="col-md-4"><label asp-for="Result.Status" class="form-label"></label><select asp-for="Result.Status" class="form-select"><option value="Passed">Passed</option><option value="Failed">Failed</option></select></div>
</div>
<div class="row mb-4">
<div class="col-md-4"><label asp-for="Result.Result" class="form-label"></label><input asp-for="Result.Result" class="form-control" /></div>
<div class="col-md-4"><label asp-for="Result.Specification" class="form-label"></label><input asp-for="Result.Specification" class="form-control" /></div>
</div>
<div class="d-flex gap-2"><button type="submit" class="btn btn-primary"><i class="bi bi-save me-1"></i>Save</button><a asp-page="/QM/Index" class="btn btn-outline-secondary"><i class="bi bi-x me-1"></i>Cancel</a></div>
</form>
</div></div>
</div></div>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }
