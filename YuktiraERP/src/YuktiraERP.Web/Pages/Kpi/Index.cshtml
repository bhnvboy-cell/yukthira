@page "/Kpi/{code?}"
@model YuktiraERP.Web.Pages.Kpi.IndexModel
@{
    ViewData["Title"] = $"{Model.KpiName} - KPI Details";
    var colorClass = Model.CurrentKpi.Color;
    var trendIcon = Model.CurrentKpi.Trend == "up" ? "bi-arrow-up" : Model.CurrentKpi.Trend == "down" ? "bi-arrow-down" : "bi-dash";
}

<div class="kpi-drill-header">
    <a href="/Dashboard" class="btn btn-outline-secondary btn-sm mb-2"><i class="bi bi-arrow-left"></i> Back to Dashboard</a>
    <h1>
        <span class="kpi-icon" style="background:rgba(var(--kpi-color,37,99,235),0.15);color:var(--kpi-color,#2563eb);width:36px;height:36px;border-radius:8px;display:inline-flex;align-items:center;justify-content:center;font-size:16px">
            <i class="bi @Model.CurrentKpi.Icon"></i>
        </span>
        @Model.KpiName
        <span class="badge bg-@(colorClass == "green" ? "success" : colorClass == "yellow" ? "warning" : "danger")">
            @Model.CurrentKpi.DisplayValue
        </span>
    </h1>
    <div class="kpi-meta">
        <span><i class="bi bi-grid-3x3-gap"></i> @Model.KpiCategory</span>
        <span><i class="bi bi-arrow-@(Model.CurrentKpi.Trend)"></i> @Model.CurrentKpi.TrendLabel vs previous period</span>
        @if (Model.CurrentKpi.PreviousValue.HasValue)
        {
            <span><i class="bi bi-clock-history"></i> Previous: @Model.CurrentKpi.PreviousValue.Value.ToString("N1")</span>
        }
    </div>
</div>

<div class="kpi-drill-main">
    <div class="kpi-drill-chart">
        <h3><i class="bi bi-graph-up"></i> 30-Day Trend</h3>
        <div style="position:relative;height:220px;display:flex;align-items:flex-end;gap:3px;padding-top:20px">
            @if (Model.History.Count > 0)
            {
                var maxVal = Model.History.Max(h => h.Value);
                var minVal = Model.History.Min(h => h.Value);
                var range = maxVal - minVal > 0 ? maxVal - minVal : 1;
                var midY = (maxVal + minVal) / 2;
                foreach (var h in Model.History)
                {
                    var pct = ((h.Value - minVal) / range * 100);
                    var barColor = h.Value >= midY ? "#059669" : h.Value >= midY * 0.85m ? "#d97706" : "#dc2626";
                    <div style="flex:1;display:flex;flex-direction:column;align-items:center;gap:2px">
                        <div style="height:@(pct.ToString("F0"))%;background:@barColor;width:100%;border-radius:3px 3px 0 0;min-height:4px;transition:height 0.3s ease" title="@h.DisplayValue"></div>
                        <span style="font-size:7px;color:var(--text-muted);white-space:nowrap;transform:rotate(-45deg);margin-top:4px">@h.Value.ToString("N0")</span>
                    </div>
                }
            }
            else
            {
                <div style="display:flex;align-items:center;justify-content:center;width:100%;height:100%;color:var(--text-muted);font-size:13px">No historical data available</div>
            }
        </div>
    </div>

    <div class="kpi-drill-sidebar">
        <div class="kpi-stat-card">
            <div class="stat-icon" style="background:rgba(5,150,105,0.15);color:#059669"><i class="bi bi-@(trendIcon)"></i></div>
            <div>
                <div class="stat-label">Trend</div>
                <div class="stat-value" style="color:@(Model.CurrentKpi.Trend == "up" ? "#059669" : Model.CurrentKpi.Trend == "down" ? "#dc2626" : "var(--text-muted)")">@Model.CurrentKpi.TrendLabel</div>
            </div>
        </div>
        <div class="kpi-stat-card">
            <div class="stat-icon" style="background:rgba(37,99,235,0.15);color:#2563eb"><i class="bi bi-calculator"></i></div>
            <div>
                <div class="stat-label">Current Value</div>
                <div class="stat-value">@Model.CurrentKpi.DisplayValue</div>
            </div>
        </div>
        <div class="kpi-stat-card">
            <div class="stat-icon" style="background:rgba(217,119,6,0.15);color:#d97706"><i class="bi bi-clock-history"></i></div>
            <div>
                <div class="stat-label">Previous Period</div>
                <div class="stat-value">@(Model.CurrentKpi.PreviousValue?.ToString("N1") ?? "N/A")</div>
            </div>
        </div>
        @if (!string.IsNullOrEmpty(Model.CurrentKpi.AlertMessage))
        {
            <div class="kpi-stat-card" style="border-left:3px solid #dc2626">
                <div class="stat-icon" style="background:rgba(220,38,38,0.15);color:#dc2626"><i class="bi bi-exclamation-triangle"></i></div>
                <div>
                    <div class="stat-label">Alert</div>
                    <div class="stat-value" style="color:#dc2626;font-size:13px">@Model.CurrentKpi.AlertMessage</div>
                </div>
            </div>
        }
    </div>
</div>

@if (Model.IsAiLoaded && Model.AiPredictions.Count > 0)
{
    <div class="kpi-ai-section">
        <h3><i class="bi bi-cpu"></i> AI Predictions &amp; Forecast</h3>
        <div class="kpi-ai-grid">
            @foreach (var p in Model.AiPredictions)
            {
                <div class="kpi-ai-card">
                    <div class="ai-label">@p.Label</div>
                    <div class="ai-value">@p.Value @p.Unit</div>
                    <span class="ai-badge risk-@p.RiskLevel">@(p.RiskLevel == "high" ? "High Risk" : p.RiskLevel == "moderate" ? "Moderate" : "Stable")</span>
                    <div style="font-size:9px;color:var(--text-muted);margin-top:4px">@p.Description</div>
                </div>
            }
        </div>
    </div>
}

<div class="kpi-drill-footer">
    <div class="card mt-3">
        <div class="card-header"><i class="bi bi-info-circle"></i> Root Cause Analysis</div>
        <div class="card-body" style="font-size:13px">
            @switch (Model.KpiCode)
            {
                case "InventoryHealth":
                    <p>Monitor slow-moving and dead stock items. Review reorder points and safety stock levels for critical materials. Items with stock below min-level for 30+ days should be escalated for procurement action.</p>
                    <p><strong>Recommended Action:</strong> Run MRP for all materials below reorder point. Review lead times with vendors for top 5 critical items.</p>
                    break;
                case "SalesToday":
                    <p>Compare today's sales against same day last week and same day last month. Analyze by customer, product category, and region to identify trends.</p>
                    <p><strong>Recommended Action:</strong> Review top 5 sales orders for today. Follow up on pending quotations over $5,000.</p>
                    break;
                case "ProductionEfficiency":
                    <p>Analyze downtime, setup time, and quality rework as percentage of total production time. Bottleneck work centers should be reviewed for capacity constraints.</p>
                    <p><strong>Recommended Action:</strong> Review work center utilization reports. Identify top 3 bottlenecks and schedule maintenance if needed.</p>
                    break;
                case "QcPassRate":
                    <p>Review failed inspection lots by material, supplier, and characteristic. Common failure modes should trigger inspection plan updates.</p>
                    <p><strong>Recommended Action:</strong> Generate failed lots report grouped by supplier. Schedule quality improvement review for materials below 90% pass rate.</p>
                    break;
                case "LimsSampleTat":
                    <p>Analyze sample TAT by test type, instrument, and lab technician. Delays in specific test groups or instruments indicate capacity constraints.</p>
                    <p><strong>Recommended Action:</strong> Review sample queue by instrument. Identify tests with TAT >48h and allocate additional resources.</p>
                    break;
                default:
                    <p>Review historical trend and correlate with operational changes. Investigate any significant deviations from expected patterns.</p>
                    break;
            }
        </div>
    </div>
</div>

@section Scripts {
<script>
    // ── KPI chart animation ──
    document.querySelectorAll('.kpi-drill-chart div[style*="height"]').forEach(function(bar) {
        var h = bar.style.height;
        bar.style.height = '0%';
        setTimeout(function() { bar.style.height = h; }, 100);
    });
</script>
}
