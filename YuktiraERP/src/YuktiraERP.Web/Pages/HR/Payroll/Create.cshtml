@page
@model YuktiraERP.Web.Pages.HR.Payroll.CreateModel
@{ ViewData["Title"] = "Create Payroll Entry"; }
<div class="row justify-content-center"><div class="col-lg-8">
<div class="card shadow-sm"><div class="card-header bg-primary text-white"><h5 class="mb-0"><i class="bi bi-plus-circle me-2"></i>Create Payroll Entry</h5></div>
<div class="card-body">
<form method="post">
<div class="row mb-3">
<div class="col-md-6"><label asp-for="Entry.EmployeeName" class="form-label"></label><input asp-for="Entry.EmployeeName" class="form-control" /></div>
<div class="col-md-3"><label asp-for="Entry.Period" class="form-label"></label><input asp-for="Entry.Period" class="form-control" placeholder="January 2024" /></div>
<div class="col-md-3"><label asp-for="Entry.Status" class="form-label"></label><select asp-for="Entry.Status" class="form-select"><option>Draft</option><option>Posted</option><option>Cancelled</option></select></div>
</div>
<div class="row mb-3">
<div class="col-md-3"><label asp-for="Entry.GrossPay" class="form-label"></label><input asp-for="Entry.GrossPay" class="form-control" /></div>
<div class="col-md-3"><label asp-for="Entry.Deductions" class="form-label"></label><input asp-for="Entry.Deductions" class="form-control" /></div>
<div class="col-md-3"><label asp-for="Entry.NetPay" class="form-label"></label><input asp-for="Entry.NetPay" class="form-control" /></div>
</div>
<div class="d-flex gap-2"><button type="submit" class="btn btn-primary"><i class="bi bi-save me-1"></i>Save</button><a asp-page="/HR/Index" class="btn btn-outline-secondary">Cancel</a></div>
</form>
</div></div>
</div></div>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }
