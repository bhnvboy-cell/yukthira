@page
@model YuktiraERP.Web.Pages.HR.EmployeeListModel
@using YuktiraERP.Infrastructure.Data.Entities
@{ ViewData["Title"] = "Employee List (PA40)"; }
<div class="d-flex justify-content-between align-items-center mb-3">
<h2><i class="bi bi-people me-2"></i>Employee List</h2>
<a asp-page="/HR/Employee/Create" class="btn btn-primary"><i class="bi bi-plus me-1"></i>New Employee</a>
</div>
<div class="card"><div class="card-body">
<table class="table table-hover table-sm datatable">
<thead><tr><th>Code</th><th>Name</th><th>Department</th><th>Designation</th><th>Mobile</th><th>Status</th><th>Actions</th></tr></thead>
<tbody>
@foreach (var e in Model.Employees)
{
<tr>
<td>@e.Code</td><td>@e.Name</td><td>@e.Department</td><td>@e.Designation</td><td>@e.Mobile</td>
<td><span class="badge bg-@(e.Status=="Active"?"success":"secondary")">@e.Status</span></td>
<td>
<a asp-page="/HR/Employee/Edit" asp-route-id="@e.Id" class="bi bi-pencil me-2 text-decoration-none text-warning"></a>
<a asp-page="/HR/Employee/Display" asp-route-id="@e.Id" class="bi bi-eye text-decoration-none text-info"></a>
</td>
</tr>
}
</tbody></table>
</div></div></div>
