@page
@model YuktiraERP.Web.Pages.HR.Leave.CreateModel
@{ ViewData["Title"] = "Create Leave Request"; }
<div class="row justify-content-center"><div class="col-lg-8">
<div class="card shadow-sm"><div class="card-header bg-primary text-white"><h5 class="mb-0"><i class="bi bi-plus-circle me-2"></i>Create Leave Request</h5></div>
<div class="card-body">
<form method="post">
<div class="row mb-3">
<div class="col-md-6"><label asp-for="LeaveRequest.EmployeeName" class="form-label"></label><input asp-for="LeaveRequest.EmployeeName" class="form-control" /></div>
<div class="col-md-3"><label asp-for="LeaveRequest.LeaveType" class="form-label"></label><select asp-for="LeaveRequest.LeaveType" class="form-select"><option>Annual</option><option>Sick</option><option>Personal</option><option>Maternity</option><option>Paternity</option></select></div>
<div class="col-md-3"><label asp-for="LeaveRequest.Status" class="form-label"></label><select asp-for="LeaveRequest.Status" class="form-select"><option>Pending</option><option>Approved</option><option>Rejected</option></select></div>
</div>
<div class="row mb-3">
<div class="col-md-6"><label asp-for="LeaveRequest.StartDate" class="form-label"></label><input asp-for="LeaveRequest.StartDate" class="form-control" type="date" /></div>
<div class="col-md-6"><label asp-for="LeaveRequest.EndDate" class="form-label"></label><input asp-for="LeaveRequest.EndDate" class="form-control" type="date" /></div>
</div>
<div class="d-flex gap-2"><button type="submit" class="btn btn-primary"><i class="bi bi-save me-1"></i>Save</button><a asp-page="/HR/Index" class="btn btn-outline-secondary">Cancel</a></div>
</form>
</div></div>
</div></div>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }
