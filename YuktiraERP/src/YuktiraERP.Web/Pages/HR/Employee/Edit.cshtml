@page
@model YuktiraERP.Web.Pages.HR.Employee.EditModel
@{ ViewData["Title"] = "Edit Employee"; }
<div class="row justify-content-center"><div class="col-lg-8">
<div class="card shadow-sm"><div class="card-header bg-warning text-dark"><h5 class="mb-0"><i class="bi bi-pencil me-2"></i>Edit Employee</h5></div>
<div class="card-body">
<form method="post">
<input type="hidden" asp-for="Employee.Id" />
<div class="row mb-3">
<div class="col-md-6"><label asp-for="Employee.Code" class="form-label"></label><input asp-for="Employee.Code" class="form-control" /><span asp-validation-for="Employee.Code" class="text-danger small"></span></div>
<div class="col-md-6"><label asp-for="Employee.Name" class="form-label"></label><input asp-for="Employee.Name" class="form-control" /><span asp-validation-for="Employee.Name" class="text-danger small"></span></div>
</div>
<div class="row mb-3">
<div class="col-md-6"><label asp-for="Employee.Department" class="form-label"></label><input asp-for="Employee.Department" class="form-control" /><span asp-validation-for="Employee.Department" class="text-danger small"></span></div>
<div class="col-md-6"><label asp-for="Employee.Designation" class="form-label"></label><input asp-for="Employee.Designation" class="form-control" /><span asp-validation-for="Employee.Designation" class="text-danger small"></span></div>
</div>
<div class="row mb-3">
<div class="col-md-6"><label asp-for="Employee.Mobile" class="form-label"></label><input asp-for="Employee.Mobile" class="form-control" /><span asp-validation-for="Employee.Mobile" class="text-danger small"></span></div>
<div class="col-md-6"><label asp-for="Employee.Status" class="form-label"></label><input asp-for="Employee.Status" class="form-control" /><span asp-validation-for="Employee.Status" class="text-danger small"></span></div>
</div>
<div class="d-flex gap-2"><button type="submit" class="btn btn-warning"><i class="bi bi-save me-1"></i>Update</button><a asp-page="/HR/Index" class="btn btn-outline-secondary"><i class="bi bi-x me-1"></i>Cancel</a></div>
</form>
</div></div>
</div></div>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }
