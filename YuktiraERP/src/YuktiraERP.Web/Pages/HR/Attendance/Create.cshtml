@page
@model YuktiraERP.Web.Pages.HR.Attendance.CreateModel
@{ ViewData["Title"] = "Mark Attendance"; }
<div class="row justify-content-center"><div class="col-lg-8">
<div class="card shadow-sm"><div class="card-header bg-primary text-white"><h5 class="mb-0"><i class="bi bi-plus-circle me-2"></i>Mark Attendance</h5></div>
<div class="card-body">
<form method="post">
<div class="row mb-3">
<div class="col-md-4"><label asp-for="Attendance.EmployeeCode" class="form-label"></label><input asp-for="Attendance.EmployeeCode" class="form-control" placeholder="EMP-..." /></div>
<div class="col-md-4"><label asp-for="Attendance.EmployeeName" class="form-label"></label><input asp-for="Attendance.EmployeeName" class="form-control" /><span asp-validation-for="Attendance.EmployeeName" class="text-danger small"></span></div>
<div class="col-md-2"><label asp-for="Attendance.Date" class="form-label"></label><input asp-for="Attendance.Date" class="form-control" type="date" /></div>
<div class="col-md-2"><label asp-for="Attendance.Status" class="form-label"></label><select asp-for="Attendance.Status" class="form-select"><option value="Present">Present</option><option value="Absent">Absent</option><option value="Half Day">Half Day</option><option value="Leave">Leave</option></select></div>
</div>
<div class="d-flex gap-2"><button type="submit" class="btn btn-primary"><i class="bi bi-save me-1"></i>Save</button><a asp-page="/HR/Index" class="btn btn-outline-secondary"><i class="bi bi-x me-1"></i>Cancel</a></div>
</form>
</div></div>
</div></div>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }
