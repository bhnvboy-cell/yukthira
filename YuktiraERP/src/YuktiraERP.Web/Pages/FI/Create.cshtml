@page
@model YuktiraERP.Web.Pages.FI.CreateModel
@{ ViewData["Title"] = "Create Journal Entry"; }
<div class="row justify-content-center"><div class="col-lg-8">
    <div class="card shadow-sm"><div class="card-header bg-primary text-white"><h5 class="mb-0"><i class="bi bi-plus-circle me-2"></i>Create Journal Entry</h5></div>
    <div class="card-body">
        <form method="post">
            <div class="row mb-3">
                <div class="col-md-4"><label asp-for="Entry.Account" class="form-label"></label><input asp-for="Entry.Account" class="form-control" placeholder="1100 - Cash" /></div>
                <div class="col-md-3"><label asp-for="Entry.Debit" class="form-label"></label><input asp-for="Entry.Debit" class="form-control" /></div>
                <div class="col-md-3"><label asp-for="Entry.Credit" class="form-label"></label><input asp-for="Entry.Credit" class="form-control" /></div>
            </div>
            <div class="row mb-3">
                <div class="col-md-4"><label asp-for="Entry.Reference" class="form-label"></label><input asp-for="Entry.Reference" class="form-control" /></div>
                <div class="col-md-4"><label asp-for="Entry.EntryDate" class="form-label"></label><input asp-for="Entry.EntryDate" class="form-control" type="date" /></div>
            </div>
            <div class="d-flex gap-2"><button type="submit" class="btn btn-primary"><i class="bi bi-save me-1"></i>Save</button><a asp-page="/FI/Index" class="btn btn-outline-secondary">Cancel</a></div>
        </form>
    </div></div>
</div></div>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }
