@page
@model YuktiraERP.Web.Pages.FI.FixedAsset.CreateModel
@{ ViewData["Title"] = "New Fixed Asset"; }
<div class="row justify-content-center"><div class="col-lg-8">
<div class="card shadow-sm"><div class="card-header bg-primary text-white"><h5 class="mb-0"><i class="bi bi-plus-circle me-2"></i>New Fixed Asset</h5></div>
<div class="card-body">
<form method="post">
<div class="row mb-3">
<div class="col-md-6"><label asp-for="Asset.AssetName" class="form-label"></label><input asp-for="Asset.AssetName" class="form-control" /><span asp-validation-for="Asset.AssetName" class="text-danger small"></span></div>
<div class="col-md-3"><label asp-for="Asset.Category" class="form-label"></label><select asp-for="Asset.Category" class="form-select"><option value="Equipment">Equipment</option><option value="Machinery">Machinery</option><option value="Vehicles">Vehicles</option><option value="Property">Property</option><option value="IT">IT</option><option value="Furniture">Furniture</option></select></div>
<div class="col-md-3"><label asp-for="Asset.Status" class="form-label"></label><select asp-for="Asset.Status" class="form-select"><option value="Active">Active</option><option value="Under Maintenance">Under Maintenance</option><option value="Disposed">Disposed</option></select></div>
</div>
<div class="row mb-3">
<div class="col-md-4"><label asp-for="Asset.PurchaseDate" class="form-label"></label><input asp-for="Asset.PurchaseDate" class="form-control" type="date" /></div>
<div class="col-md-4"><label asp-for="Asset.Cost" class="form-label"></label><input asp-for="Asset.Cost" class="form-control" min="0" step="0.01" /><span asp-validation-for="Asset.Cost" class="text-danger small"></span></div>
<div class="col-md-4"><label asp-for="Asset.SalvageValue" class="form-label"></label><input asp-for="Asset.SalvageValue" class="form-control" min="0" step="0.01" /><span asp-validation-for="Asset.SalvageValue" class="text-danger small"></span></div>
</div>
<div class="row mb-4">
<div class="col-md-4"><label asp-for="Asset.UsefulLifeYears" class="form-label"></label><input asp-for="Asset.UsefulLifeYears" class="form-control" min="1" max="50" step="1" /><span asp-validation-for="Asset.UsefulLifeYears" class="text-danger small"></span></div>
</div>
<div class="d-flex gap-2"><button type="submit" class="btn btn-primary"><i class="bi bi-save me-1"></i>Save</button><a asp-page="/FI/Index" class="btn btn-outline-secondary"><i class="bi bi-x me-1"></i>Cancel</a></div>
</form>
</div></div>
</div></div>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }
