@page
@model YuktiraERP.Web.Pages.FI.AR.ListModel
@using YuktiraERP.Infrastructure.Data.Entities
@{ ViewData["Title"] = "AR Customer Line Items (FBL5N)"; }
<h2><i class="bi bi-journal-text me-2"></i>AR Customer Line Items</h2>
<div class="card mt-3"><div class="card-body">
<table class="table table-hover table-sm datatable">
<thead><tr><th>Document #</th><th>Date</th><th>Customer</th><th>Amount</th><th>Received</th><th>Status</th></tr></thead>
<tbody>
@foreach (var e in Model.Entries)
{
<tr>
<td>@e.DocumentNumber</td><td>@e.Date.ToString("d")</td><td>@e.CustomerName</td>
<td>@e.Amount.ToString("C2")</td><td>@e.ReceivedAmount.ToString("C2")</td>
<td><span class="badge bg-@(e.Status=="Paid"?"success":"warning")">@e.Status</span></td>
</tr>
}
</tbody></table>
</div></div></div>
