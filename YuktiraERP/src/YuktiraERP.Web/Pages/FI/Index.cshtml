@page
@model YuktiraERP.Web.Pages.FI.IndexModel
@using YuktiraERP.Infrastructure.Data.Entities
@{
    ViewData["Title"] = "Finance";
    var entries = Model.JournalEntries;
    var assets = Model.FixedAssets;
}
<div class="d-flex justify-content-between align-items-center mb-3">
    <h2><i class="bi bi-calculator me-2"></i>Finance</h2>
    <div><a asp-page="/FI/Ledger/Create" class="btn btn-primary btn-sm"><i class="bi bi-plus"></i> New Journal Entry</a></div>
</div>
<ul class="nav nav-tabs mb-3">
    <li class="nav-item"><a class="nav-link active" data-bs-toggle="tab" href="#gl">General Ledger</a></li>
    <li class="nav-item"><a class="nav-link" data-bs-toggle="tab" href="#ap">Accounts Payable</a></li>
    <li class="nav-item"><a class="nav-link" data-bs-toggle="tab" href="#ar">Accounts Receivable</a></li>
    <li class="nav-item"><a class="nav-link" data-bs-toggle="tab" href="#assets">Fixed Assets</a></li>
    <li class="nav-item"><a class="nav-link" data-bs-toggle="tab" href="#reports">Financial Reports</a></li>
</ul>
<div class="tab-content">
    <div class="tab-pane fade show active" id="gl">
        <div class="card"><div class="card-body">
            <table class="table table-hover table-sm">
                <thead><tr><th>Date</th><th>Document</th><th>Account</th><th>Debit</th><th>Credit</th><th>Reference</th><th>Actions</th></tr></thead>
                <tbody>
                    @foreach (var e in entries)
                    {
                        <tr>
                            <td>@e.EntryDate.ToString("d")</td><td>@e.DocumentNumber</td><td>@e.Account</td>
                            <td>@(e.Debit.HasValue ? e.Debit.Value.ToString("C2") : "--")</td>
                            <td>@(e.Credit.HasValue ? e.Credit.Value.ToString("C2") : "--")</td>
                            <td>@e.Reference</td>
                            <td><i class="bi bi-eye"></i></td>
                        </tr>
                    }
                </tbody>
            </table>
        </div></div>
    </div>
    <div class="tab-pane fade" id="ap"><div class="card"><div class="card-body"><div class="mb-2"><a asp-page="/FI/AP/Create" class="btn btn-outline-primary btn-sm"><i class="bi bi-plus"></i> New AP Entry</a></div><p class="text-muted">Vendor invoice processing, payment runs, aging analysis, and dunning.</p></div></div></div>
    <div class="tab-pane fade" id="ar"><div class="card"><div class="card-body"><div class="mb-2"><a asp-page="/FI/AR/Create" class="btn btn-outline-primary btn-sm"><i class="bi bi-plus"></i> New AR Entry</a></div><p class="text-muted">Customer invoices, incoming payments, credit management, and aging reports.</p></div></div></div>
    <div class="tab-pane fade" id="assets"><div class="card"><div class="card-body"><div class="mb-2"><a asp-page="/FI/FixedAsset/Create" class="btn btn-outline-primary btn-sm"><i class="bi bi-plus"></i> New Asset</a></div><table class="table table-hover table-sm"><thead><tr><th>Code</th><th>Name</th><th>Category</th><th>Purchase Date</th><th>Cost</th><th>Life (Yrs)</th><th>Status</th><th>Actions</th></tr></thead><tbody>@foreach(var a in assets){<tr><td>@a.AssetCode</td><td>@a.AssetName</td><td>@a.Category</td><td>@a.PurchaseDate.ToString("d")</td><td>@a.Cost.ToString("C0")</td><td>@a.UsefulLifeYears</td><td><span class="badge @(a.Status=="Active"?"bg-success":"bg-warning")">@a.Status</span></td><td><i class="bi bi-pencil"></i></td></tr>}</tbody></table></div></div></div>
    <div class="tab-pane fade" id="reports"><div class="card"><div class="card-body"><p class="text-muted">Trial balance, P&L statement, balance sheet, cash flow, and custom financial reports.</p></div></div></div>
</div>
