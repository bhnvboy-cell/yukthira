@page
@model YuktiraERP.Web.Pages.FI.AP.PaymentModel
@{ ViewData["Title"] = "AP Payment (F-03)"; }
<div class="row justify-content-center"><div class="col-lg-6">
<div class="card shadow-sm"><div class="card-header bg-primary text-white"><h5 class="mb-0"><i class="bi bi-credit-card me-2"></i>AP Payment</h5></div>
<div class="card-body">
<form method="post">
<div class="mb-3"><label asp-for="VendorName" class="form-label"></label><input asp-for="VendorName" class="form-control" /></div>
<div class="mb-3"><label asp-for="Amount" class="form-label"></label><input asp-for="Amount" class="form-control" type="number" step="0.01" /></div>
<div class="mb-3"><label asp-for="PaymentDate" class="form-label"></label><input asp-for="PaymentDate" class="form-control" type="date" /></div>
<button type="submit" class="btn btn-primary"><i class="bi bi-check me-1"></i>Record Payment</button>
</form>
@if (!string.IsNullOrEmpty(Model.Message)) { <div class="alert alert-success mt-3">@Model.Message</div> }
</div></div>
</div></div>
