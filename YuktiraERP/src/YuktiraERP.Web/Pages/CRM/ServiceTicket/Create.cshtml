@page
@model YuktiraERP.Web.Pages.CRM.ServiceTicket.CreateModel
@{ ViewData["Title"] = "New Service Ticket"; }
<div class="row justify-content-center"><div class="col-lg-8">
<div class="card shadow-sm"><div class="card-header bg-primary text-white"><h5 class="mb-0"><i class="bi bi-plus-circle me-2"></i>New Service Ticket</h5></div>
<div class="card-body">
<form method="post">
<div class="row mb-3">
<div class="col-md-6"><label asp-for="Ticket.CustomerName" class="form-label"></label><input asp-for="Ticket.CustomerName" class="form-control" /><span asp-validation-for="Ticket.CustomerName" class="text-danger small"></span></div>
<div class="col-md-3"><label asp-for="Ticket.Priority" class="form-label"></label><select asp-for="Ticket.Priority" class="form-select"><option value="Low">Low</option><option value="Medium">Medium</option><option value="High">High</option><option value="Critical">Critical</option></select></div>
<div class="col-md-3"><label asp-for="Ticket.Status" class="form-label"></label><select asp-for="Ticket.Status" class="form-select"><option value="Open">Open</option><option value="In Progress">In Progress</option><option value="Resolved">Resolved</option><option value="Closed">Closed</option></select></div>
</div>
<div class="mb-4"><label asp-for="Ticket.Subject" class="form-label"></label><textarea asp-for="Ticket.Subject" class="form-control" rows="2"></textarea><span asp-validation-for="Ticket.Subject" class="text-danger small"></span></div>
<div class="d-flex gap-2"><button type="submit" class="btn btn-primary"><i class="bi bi-save me-1"></i>Save</button><a asp-page="/CRM/Index" class="btn btn-outline-secondary"><i class="bi bi-x me-1"></i>Cancel</a></div>
</form>
</div></div>
</div></div>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }
