@page
@model YuktiraERP.Web.Pages.CRM.Lead.CreateModel
@{ ViewData["Title"] = "Create Lead"; }
<div class="row justify-content-center"><div class="col-lg-8">
<div class="card shadow-sm"><div class="card-header bg-primary text-white"><h5 class="mb-0"><i class="bi bi-plus-circle me-2"></i>Create Lead</h5></div>
<div class="card-body">
<form method="post">
<div class="row mb-3">
<div class="col-md-6"><label asp-for="Lead.Company" class="form-label"></label><input asp-for="Lead.Company" class="form-control" /></div>
<div class="col-md-6"><label asp-for="Lead.Contact" class="form-label"></label><input asp-for="Lead.Contact" class="form-control" /></div>
</div>
<div class="row mb-3">
<div class="col-md-4"><label asp-for="Lead.Source" class="form-label"></label><select asp-for="Lead.Source" class="form-select"><option>Website</option><option>Referral</option><option>Trade Show</option><option>Cold Call</option><option>Social Media</option></select></div>
<div class="col-md-4"><label asp-for="Lead.Value" class="form-label"></label><input asp-for="Lead.Value" class="form-control" /></div>
<div class="col-md-4"><label asp-for="Lead.Status" class="form-label"></label><select asp-for="Lead.Status" class="form-select"><option>New</option><option>Qualified</option><option>Converted</option><option>Lost</option></select></div>
</div>
<div class="d-flex gap-2"><button type="submit" class="btn btn-primary"><i class="bi bi-save me-1"></i>Save</button><a asp-page="/CRM/Index" class="btn btn-outline-secondary">Cancel</a></div>
</form>
</div></div>
</div></div>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }
