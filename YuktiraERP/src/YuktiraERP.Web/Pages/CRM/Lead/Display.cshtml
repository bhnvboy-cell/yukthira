@page
@model YuktiraERP.Web.Pages.CRM.Lead.DisplayModel
@using YuktiraERP.Infrastructure.Data.Entities
@{ ViewData["Title"] = "Lead Details"; }
<div class="row justify-content-center"><div class="col-lg-8">
<div class="card shadow-sm"><div class="card-header bg-info text-white"><h5 class="mb-0"><i class="bi bi-eye me-2"></i>Lead Details</h5></div>
<div class="card-body">
<dl class="row mb-0">
<dt class="col-sm-4">LeadId</dt><dd class="col-sm-8">@Model.Lead.LeadId</dd>
<dt class="col-sm-4">Company</dt><dd class="col-sm-8">@Model.Lead.Company</dd>
<dt class="col-sm-4">Contact</dt><dd class="col-sm-8">@Model.Lead.Contact</dd>
<dt class="col-sm-4">Source</dt><dd class="col-sm-8">@Model.Lead.Source</dd>
<dt class="col-sm-4">Value</dt><dd class="col-sm-8">@Model.Lead.Value</dd>
<dt class="col-sm-4">Status</dt><dd class="col-sm-8">@Model.Lead.Status</dd>
</dl>
</div>
<div class="card-footer">
<a asp-page="/CRM/Index" class="btn btn-outline-secondary"><i class="bi bi-arrow-left me-1"></i>Back</a>
<a asp-page="/CRM/Lead/Edit" asp-route-id="@Model.Lead.Id" class="btn btn-warning"><i class="bi bi-pencil me-1"></i>Edit</a>
</div>
</div></div>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }
