@page
@model YuktiraERP.Web.Pages.CRM.Campaign.CreateModel
@{ ViewData["Title"] = "New Campaign"; }
<div class="row justify-content-center"><div class="col-lg-8">
<div class="card shadow-sm"><div class="card-header bg-primary text-white"><h5 class="mb-0"><i class="bi bi-plus-circle me-2"></i>New Campaign</h5></div>
<div class="card-body">
<form method="post">
<div class="row mb-3">
<div class="col-md-6"><label asp-for="Campaign.Name" class="form-label"></label><input asp-for="Campaign.Name" class="form-control" /><span asp-validation-for="Campaign.Name" class="text-danger small"></span></div>
<div class="col-md-3"><label asp-for="Campaign.Type" class="form-label"></label><select asp-for="Campaign.Type" class="form-select"><option value="Email">Email</option><option value="Social Media">Social Media</option><option value="Trade Show">Trade Show</option><option value="Direct Mail">Direct Mail</option></select></div>
<div class="col-md-3"><label asp-for="Campaign.Status" class="form-label"></label><select asp-for="Campaign.Status" class="form-select"><option value="Draft">Draft</option><option value="Active">Active</option><option value="Completed">Completed</option></select></div>
</div>
<div class="row mb-3">
<div class="col-md-4"><label asp-for="Campaign.StartDate" class="form-label"></label><input asp-for="Campaign.StartDate" class="form-control" type="date" /></div>
<div class="col-md-4"><label asp-for="Campaign.EndDate" class="form-label"></label><input asp-for="Campaign.EndDate" class="form-control" type="date" /></div>
<div class="col-md-4"><label asp-for="Campaign.Budget" class="form-label"></label><input asp-for="Campaign.Budget" class="form-control" min="0" step="0.01" /><span asp-validation-for="Campaign.Budget" class="text-danger small"></span></div>
</div>
<div class="d-flex gap-2"><button type="submit" class="btn btn-primary"><i class="bi bi-save me-1"></i>Save</button><a asp-page="/CRM/Index" class="btn btn-outline-secondary"><i class="bi bi-x me-1"></i>Cancel</a></div>
</form>
</div></div>
</div></div>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }
