@page
@model YuktiraERP.Web.Pages.CRM.IndexModel
@using YuktiraERP.Infrastructure.Data.Entities
@{
    ViewData["Title"] = "Customer Relationship Management";
    var leads = Model.Leads;
    var contacts = Model.Contacts;
    var campaigns = Model.Campaigns;
    var tickets = Model.ServiceTickets;
}
<div class="d-flex justify-content-between align-items-center mb-3">
    <h2><i class="bi bi-person-lines-fill me-2"></i>CRM</h2>
    <div><a asp-page="/CRM/Lead/Create" class="btn btn-primary btn-sm"><i class="bi bi-plus"></i> New Lead</a></div>
</div>
<ul class="nav nav-tabs mb-3">
    <li class="nav-item"><a class="nav-link active" data-bs-toggle="tab" href="#leads">Leads</a></li>
    <li class="nav-item"><a class="nav-link" data-bs-toggle="tab" href="#contacts">Contacts</a></li>
    <li class="nav-item"><a class="nav-link" data-bs-toggle="tab" href="#opportunities">Opportunities</a></li>
    <li class="nav-item"><a class="nav-link" data-bs-toggle="tab" href="#campaigns">Campaigns</a></li>
    <li class="nav-item"><a class="nav-link" data-bs-toggle="tab" href="#service">Service</a></li>
</ul>
<div class="tab-content">
    <div class="tab-pane fade show active" id="leads">
        <div class="card"><div class="card-body">
            <table class="table table-hover table-sm">
                <thead><tr><th>Lead ID</th><th>Company</th><th>Contact</th><th>Source</th><th>Value</th><th>Status</th><th>Actions</th></tr></thead>
                <tbody>
                    @foreach (var l in leads)
                    {
                        <tr>
                            <td>@l.LeadId</td><td>@l.Company</td><td>@l.Contact</td><td>@l.Source</td><td>@l.Value.ToString("C0")</td>
                            <td><span class="badge @(l.Status=="New"?"bg-info":l.Status=="Qualified"?"bg-warning":"bg-success")">@l.Status</span></td>
                            <td><i class="bi bi-pencil me-2"></i><i class="bi bi-arrow-right"></i></td>
                        </tr>
                    }
                </tbody>
            </table>
        </div></div>
    </div>
    <div class="tab-pane fade" id="contacts"><div class="card"><div class="card-body"><div class="mb-2"><a asp-page="/CRM/Contact/Create" class="btn btn-outline-primary btn-sm"><i class="bi bi-plus"></i> New Contact</a></div><table class="table table-hover table-sm"><thead><tr><th>ID</th><th>Name</th><th>Email</th><th>Phone</th><th>Company</th><th>Status</th><th>Actions</th></tr></thead><tbody>@foreach(var c in contacts){<tr><td>@c.ContactId</td><td>@c.Name</td><td>@c.Email</td><td>@c.Phone</td><td>@c.Company</td><td><span class="badge bg-success">@c.Status</span></td><td><i class="bi bi-pencil"></i></td></tr>}</tbody></table></div></div></div>
    <div class="tab-pane fade" id="opportunities"><div class="card"><div class="card-body"><div class="mb-2"><a asp-page="/CRM/Opportunity/Create" class="btn btn-outline-primary btn-sm"><i class="bi bi-plus"></i> New Opportunity</a></div><p class="text-muted">Pipeline tracking with stages, probability, expected close date, and sales forecasting.</p></div></div></div>
    <div class="tab-pane fade" id="campaigns"><div class="card"><div class="card-body"><div class="mb-2"><a asp-page="/CRM/Campaign/Create" class="btn btn-outline-primary btn-sm"><i class="bi bi-plus"></i> New Campaign</a></div><table class="table table-hover table-sm"><thead><tr><th>ID</th><th>Name</th><th>Type</th><th>Start</th><th>End</th><th>Budget</th><th>Status</th><th>Actions</th></tr></thead><tbody>@foreach(var c in campaigns){<tr><td>@c.CampaignId</td><td>@c.Name</td><td>@c.Type</td><td>@c.StartDate.ToString("d")</td><td>@c.EndDate.ToString("d")</td><td>@c.Budget.ToString("C0")</td><td><span class="badge @(c.Status=="Active"?"bg-success":"bg-secondary")">@c.Status</span></td><td><i class="bi bi-pencil"></i></td></tr>}</tbody></table></div></div></div>
    <div class="tab-pane fade" id="service"><div class="card"><div class="card-body"><div class="mb-2"><a asp-page="/CRM/ServiceTicket/Create" class="btn btn-outline-primary btn-sm"><i class="bi bi-plus"></i> New Ticket</a></div><table class="table table-hover table-sm"><thead><tr><th>Ticket ID</th><th>Customer</th><th>Subject</th><th>Priority</th><th>Status</th><th>Date</th><th>Actions</th></tr></thead><tbody>@foreach(var t in tickets){<tr><td>@t.TicketId</td><td>@t.CustomerName</td><td>@t.Subject</td><td><span class="badge @(t.Priority=="High"?"bg-danger":t.Priority=="Medium"?"bg-warning":"bg-info")">@t.Priority</span></td><td><span class="badge bg-info">@t.Status</span></td><td>@t.CreatedDate.ToString("d")</td><td><i class="bi bi-eye"></i></td></tr>}</tbody></table></div></div></div>
</div>
