@page
@model YuktiraERP.Web.Pages.CRM.Opportunity.CreateModel
@{ ViewData["Title"] = "Create Opportunity"; }
<div class="row justify-content-center"><div class="col-lg-8">
<div class="card shadow-sm"><div class="card-header bg-primary text-white"><h5 class="mb-0"><i class="bi bi-plus-circle me-2"></i>Create Opportunity</h5></div>
<div class="card-body">
<form method="post">
<div class="row mb-3">
<div class="col-md-6"><label asp-for="Opportunity.OpportunityName" class="form-label"></label><input asp-for="Opportunity.OpportunityName" class="form-control" /></div>
<div class="col-md-6"><label asp-for="Opportunity.Company" class="form-label"></label><input asp-for="Opportunity.Company" class="form-control" /></div>
</div>
<div class="row mb-3">
<div class="col-md-4"><label asp-for="Opportunity.Value" class="form-label"></label><input asp-for="Opportunity.Value" class="form-control" /></div>
<div class="col-md-4"><label asp-for="Opportunity.Stage" class="form-label"></label><select asp-for="Opportunity.Stage" class="form-select"><option>Prospecting</option><option>Qualification</option><option>Proposal</option><option>Negotiation</option><option>Closed Won</option><option>Closed Lost</option></select></div>
<div class="col-md-4"><label asp-for="Opportunity.Status" class="form-label"></label><select asp-for="Opportunity.Status" class="form-select"><option>Open</option><option>Won</option><option>Lost</option></select></div>
</div>
<div class="d-flex gap-2"><button type="submit" class="btn btn-primary"><i class="bi bi-save me-1"></i>Save</button><a asp-page="/CRM/Index" class="btn btn-outline-secondary">Cancel</a></div>
</form>
</div></div>
</div></div>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }
