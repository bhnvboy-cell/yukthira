@page
@model YuktiraERP.Web.Pages.CRM.Opportunity.EditModel
@{ ViewData["Title"] = "Edit Opportunity"; }
<div class="row justify-content-center"><div class="col-lg-8">
<div class="card shadow-sm"><div class="card-header bg-warning text-dark"><h5 class="mb-0"><i class="bi bi-pencil me-2"></i>Edit Opportunity</h5></div>
<div class="card-body">
<form method="post">
<input type="hidden" asp-for="Opportunity.Id" />
<div class="row mb-3">
<div class="col-md-6"><label asp-for="Opportunity.OppId" class="form-label"></label><input asp-for="Opportunity.OppId" class="form-control" /><span asp-validation-for="Opportunity.OppId" class="text-danger small"></span></div>
<div class="col-md-6"><label asp-for="Opportunity.OpportunityName" class="form-label"></label><input asp-for="Opportunity.OpportunityName" class="form-control" /><span asp-validation-for="Opportunity.OpportunityName" class="text-danger small"></span></div>
</div>
<div class="row mb-3">
<div class="col-md-6"><label asp-for="Opportunity.Company" class="form-label"></label><input asp-for="Opportunity.Company" class="form-control" /><span asp-validation-for="Opportunity.Company" class="text-danger small"></span></div>
<div class="col-md-6"><label asp-for="Opportunity.Value" class="form-label"></label><input asp-for="Opportunity.Value" class="form-control" /><span asp-validation-for="Opportunity.Value" class="text-danger small"></span></div>
</div>
<div class="row mb-3">
<div class="col-md-6"><label asp-for="Opportunity.Stage" class="form-label"></label><input asp-for="Opportunity.Stage" class="form-control" /><span asp-validation-for="Opportunity.Stage" class="text-danger small"></span></div>
<div class="col-md-6"><label asp-for="Opportunity.Status" class="form-label"></label><input asp-for="Opportunity.Status" class="form-control" /><span asp-validation-for="Opportunity.Status" class="text-danger small"></span></div>
</div>
<div class="d-flex gap-2"><button type="submit" class="btn btn-warning"><i class="bi bi-save me-1"></i>Update</button><a asp-page="/CRM/Index" class="btn btn-outline-secondary"><i class="bi bi-x me-1"></i>Cancel</a></div>
</form>
</div></div>
</div></div>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }
