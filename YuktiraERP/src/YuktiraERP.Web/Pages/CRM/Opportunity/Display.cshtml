@page
@model YuktiraERP.Web.Pages.CRM.Opportunity.DisplayModel
@using YuktiraERP.Infrastructure.Data.Entities
@{ ViewData["Title"] = "Opportunity Details"; }
<div class="row justify-content-center"><div class="col-lg-8">
<div class="card shadow-sm"><div class="card-header bg-info text-white"><h5 class="mb-0"><i class="bi bi-eye me-2"></i>Opportunity Details</h5></div>
<div class="card-body">
<dl class="row mb-0">
<dt class="col-sm-4">OppId</dt><dd class="col-sm-8">@Model.Opportunity.OppId</dd>
<dt class="col-sm-4">OpportunityName</dt><dd class="col-sm-8">@Model.Opportunity.OpportunityName</dd>
<dt class="col-sm-4">Company</dt><dd class="col-sm-8">@Model.Opportunity.Company</dd>
<dt class="col-sm-4">Value</dt><dd class="col-sm-8">@Model.Opportunity.Value</dd>
<dt class="col-sm-4">Stage</dt><dd class="col-sm-8">@Model.Opportunity.Stage</dd>
<dt class="col-sm-4">Status</dt><dd class="col-sm-8">@Model.Opportunity.Status</dd>
</dl>
</div>
<div class="card-footer">
<a asp-page="/CRM/Index" class="btn btn-outline-secondary"><i class="bi bi-arrow-left me-1"></i>Back</a>
<a asp-page="/CRM/Opportunity/Edit" asp-route-id="@Model.Opportunity.Id" class="btn btn-warning"><i class="bi bi-pencil me-1"></i>Edit</a>
</div>
</div></div>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }
