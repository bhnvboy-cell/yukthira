@page
@model YuktiraERP.Web.Pages.SD.Quotation.CreateModel
@{ ViewData["Title"] = "New Quotation"; }
<div class="row justify-content-center"><div class="col-lg-8">
<div class="card shadow-sm"><div class="card-header bg-primary text-white"><h5 class="mb-0"><i class="bi bi-plus-circle me-2"></i>New Quotation</h5></div>
<div class="card-body">
<form method="post">
<div class="row mb-3">
<div class="col-md-6"><label asp-for="Quote.CustomerName" class="form-label"></label><input asp-for="Quote.CustomerName" class="form-control" /><span asp-validation-for="Quote.CustomerName" class="text-danger small"></span></div>
<div class="col-md-3"><label asp-for="Quote.Date" class="form-label"></label><input asp-for="Quote.Date" class="form-control" type="date" /></div>
<div class="col-md-3"><label asp-for="Quote.ValidUntil" class="form-label"></label><input asp-for="Quote.ValidUntil" class="form-control" type="date" /></div>
</div>
<div class="row mb-3">
<div class="col-md-4"><label asp-for="Quote.Amount" class="form-label"></label><input asp-for="Quote.Amount" class="form-control" min="0" step="0.01" /><span asp-validation-for="Quote.Amount" class="text-danger small"></span></div>
<div class="col-md-4"><label asp-for="Quote.Status" class="form-label"></label><select asp-for="Quote.Status" class="form-select"><option value="Draft">Draft</option><option value="Sent">Sent</option><option value="Accepted">Accepted</option><option value="Rejected">Rejected</option></select></div>
</div>
<div class="d-flex gap-2"><button type="submit" class="btn btn-primary"><i class="bi bi-save me-1"></i>Save</button><a asp-page="/SD/Index" class="btn btn-outline-secondary"><i class="bi bi-x me-1"></i>Cancel</a></div>
</form>
</div></div>
</div></div>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }
