@page
@model YuktiraERP.Web.Pages.SD.Delivery.CreateModel
@{ ViewData["Title"] = "New Delivery"; }
<div class="row justify-content-center"><div class="col-lg-8">
<div class="card shadow-sm"><div class="card-header bg-primary text-white"><h5 class="mb-0"><i class="bi bi-plus-circle me-2"></i>New Delivery Note</h5></div>
<div class="card-body">
<form method="post">
<div class="row mb-3">
<div class="col-md-4"><label asp-for="Delivery.SoNumber" class="form-label"></label><input asp-for="Delivery.SoNumber" class="form-control" placeholder="SO-2024-..." /><span asp-validation-for="Delivery.SoNumber" class="text-danger small"></span></div>
<div class="col-md-4"><label asp-for="Delivery.CustomerName" class="form-label"></label><input asp-for="Delivery.CustomerName" class="form-control" /><span asp-validation-for="Delivery.CustomerName" class="text-danger small"></span></div>
<div class="col-md-4"><label asp-for="Delivery.Date" class="form-label"></label><input asp-for="Delivery.Date" class="form-control" type="date" /></div>
</div>
<div class="row mb-4">
<div class="col-md-4"><label asp-for="Delivery.Status" class="form-label"></label><select asp-for="Delivery.Status" class="form-select"><option value="Picked">Picked</option><option value="Packed">Packed</option><option value="Shipped">Shipped</option><option value="Delivered">Delivered</option></select></div>
</div>
<div class="d-flex gap-2"><button type="submit" class="btn btn-primary"><i class="bi bi-save me-1"></i>Save</button><a asp-page="/SD/Index" class="btn btn-outline-secondary"><i class="bi bi-x me-1"></i>Cancel</a></div>
</form>
</div></div>
</div></div>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }
