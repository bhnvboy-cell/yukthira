@page
@model YuktiraERP.Web.Pages.SD.Billing.CreateModel
@{ ViewData["Title"] = "New Invoice"; }
<div class="row justify-content-center"><div class="col-lg-8">
<div class="card shadow-sm"><div class="card-header bg-primary text-white"><h5 class="mb-0"><i class="bi bi-plus-circle me-2"></i>New Invoice</h5></div>
<div class="card-body">
<form method="post">
<div class="row mb-3">
<div class="col-md-4"><label asp-for="Invoice.SoNumber" class="form-label"></label><input asp-for="Invoice.SoNumber" class="form-control" placeholder="SO-2024-..." /><span asp-validation-for="Invoice.SoNumber" class="text-danger small"></span></div>
<div class="col-md-4"><label asp-for="Invoice.CustomerName" class="form-label"></label><input asp-for="Invoice.CustomerName" class="form-control" /><span asp-validation-for="Invoice.CustomerName" class="text-danger small"></span></div>
<div class="col-md-4"><label asp-for="Invoice.Date" class="form-label"></label><input asp-for="Invoice.Date" class="form-control" type="date" /></div>
</div>
<div class="row mb-3">
<div class="col-md-4"><label asp-for="Invoice.Amount" class="form-label"></label><input asp-for="Invoice.Amount" class="form-control" min="0" step="0.01" /><span asp-validation-for="Invoice.Amount" class="text-danger small"></span></div>
<div class="col-md-4"><label asp-for="Invoice.Status" class="form-label"></label><select asp-for="Invoice.Status" class="form-select"><option value="Unpaid">Unpaid</option><option value="Paid">Paid</option><option value="Overdue">Overdue</option></select></div>
</div>
<div class="d-flex gap-2"><button type="submit" class="btn btn-primary"><i class="bi bi-save me-1"></i>Save</button><a asp-page="/SD/Index" class="btn btn-outline-secondary"><i class="bi bi-x me-1"></i>Cancel</a></div>
</form>
</div></div>
</div></div>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }
