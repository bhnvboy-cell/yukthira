@page
@model YuktiraERP.Web.Pages.SD.SalesOrder.ListModel
@using YuktiraERP.Infrastructure.Data.Entities
@{ ViewData["Title"] = "Sales Order List"; }
<div class="d-flex justify-content-between align-items-center mb-3">
<h2><i class="bi bi-file-text me-2"></i>Sales Orders</h2>
<a asp-page="/SD/SalesOrder/Create" class="btn btn-primary"><i class="bi bi-plus me-1"></i>New Sales Order</a>
</div>
<div class="card"><div class="card-body">
<div class="table-responsive">
<table class="table table-hover table-sm datatable">
<thead><tr><th>Order #</th><th>Customer</th><th>Date</th><th>Items</th><th>Amount</th><th>Status</th><th>Actions</th></tr></thead>
<tbody>
@foreach (var o in Model.Orders)
{
<tr>
<td>@o.OrderNumber</td><td>@o.CustomerName</td><td>@o.OrderDate.ToString("d")</td><td>@o.ItemCount</td><td>@o.Amount.ToString("C2")</td>
<td><span class="badge bg-@(o.Status=="Completed"?"success":o.Status=="Confirmed"?"primary":"secondary")">@o.Status</span></td>
<td>
<a asp-page="/SD/SalesOrder/Edit" asp-route-id="@o.Id" class="bi bi-pencil me-2 text-decoration-none text-warning"></a>
<a asp-page="/SD/SalesOrder/Display" asp-route-id="@o.Id" class="bi bi-eye text-decoration-none text-info"></a>
</td>
</tr>
}
</tbody></table>
</div></div></div>
