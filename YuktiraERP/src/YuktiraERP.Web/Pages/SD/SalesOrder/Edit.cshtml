@page
@model YuktiraERP.Web.Pages.SD.SalesOrder.EditModel
@{ ViewData["Title"] = "Edit Sales Order"; }
<div class="row justify-content-center"><div class="col-lg-8">
<div class="card shadow-sm"><div class="card-header bg-warning text-dark"><h5 class="mb-0"><i class="bi bi-pencil me-2"></i>Edit Sales Order</h5></div>
<div class="card-body">
<form method="post">
<input type="hidden" asp-for="Order.Id" />
<div class="row mb-3">
<div class="col-md-6"><label asp-for="Order.OrderNumber" class="form-label"></label><input asp-for="Order.OrderNumber" class="form-control" /><span asp-validation-for="Order.OrderNumber" class="text-danger small"></span></div>
<div class="col-md-6"><label asp-for="Order.CustomerName" class="form-label"></label><input asp-for="Order.CustomerName" class="form-control" /><span asp-validation-for="Order.CustomerName" class="text-danger small"></span></div>
</div>
<div class="row mb-3">
<div class="col-md-6"><label asp-for="Order.OrderDate" class="form-label"></label><input asp-for="Order.OrderDate" class="form-control" /><span asp-validation-for="Order.OrderDate" class="text-danger small"></span></div>
<div class="col-md-6"><label asp-for="Order.ItemCount" class="form-label"></label><input asp-for="Order.ItemCount" class="form-control" /><span asp-validation-for="Order.ItemCount" class="text-danger small"></span></div>
</div>
<div class="row mb-3">
<div class="col-md-6"><label asp-for="Order.Amount" class="form-label"></label><input asp-for="Order.Amount" class="form-control" /><span asp-validation-for="Order.Amount" class="text-danger small"></span></div>
<div class="col-md-6"><label asp-for="Order.Status" class="form-label"></label><input asp-for="Order.Status" class="form-control" /><span asp-validation-for="Order.Status" class="text-danger small"></span></div>
</div>
<div class="d-flex gap-2"><button type="submit" class="btn btn-warning"><i class="bi bi-save me-1"></i>Update</button><a asp-page="/SD/Index" class="btn btn-outline-secondary"><i class="bi bi-x me-1"></i>Cancel</a></div>
</form>
</div></div>
</div></div>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }
