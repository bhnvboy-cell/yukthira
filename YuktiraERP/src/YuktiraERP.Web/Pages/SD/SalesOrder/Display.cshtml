@page
@model YuktiraERP.Web.Pages.SD.SalesOrder.DisplayModel
@using YuktiraERP.Infrastructure.Data.Entities
@{ ViewData["Title"] = "Sales Order Details"; }
<div class="row justify-content-center"><div class="col-lg-8">
<div class="card shadow-sm"><div class="card-header bg-info text-white"><h5 class="mb-0"><i class="bi bi-eye me-2"></i>Sales Order Details</h5></div>
<div class="card-body">
<dl class="row mb-0">
<dt class="col-sm-4">OrderNumber</dt><dd class="col-sm-8">@Model.Order.OrderNumber</dd>
<dt class="col-sm-4">CustomerName</dt><dd class="col-sm-8">@Model.Order.CustomerName</dd>
<dt class="col-sm-4">OrderDate</dt><dd class="col-sm-8">@Model.Order.OrderDate</dd>
<dt class="col-sm-4">ItemCount</dt><dd class="col-sm-8">@Model.Order.ItemCount</dd>
<dt class="col-sm-4">Amount</dt><dd class="col-sm-8">@Model.Order.Amount</dd>
<dt class="col-sm-4">Status</dt><dd class="col-sm-8">@Model.Order.Status</dd>
</dl>
</div>
<div class="card-footer">
<a asp-page="/SD/Index" class="btn btn-outline-secondary"><i class="bi bi-arrow-left me-1"></i>Back</a>
<a asp-page="/SD/SalesOrder/Edit" asp-route-id="@Model.Order.Id" class="btn btn-warning"><i class="bi bi-pencil me-1"></i>Edit</a>
</div>
</div></div>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }
