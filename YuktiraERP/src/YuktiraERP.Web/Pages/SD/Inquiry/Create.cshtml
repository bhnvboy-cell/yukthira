@page
@model YuktiraERP.Web.Pages.SD.Inquiry.CreateModel
@{ ViewData["Title"] = "New Inquiry"; }
<div class="row justify-content-center"><div class="col-lg-8">
<div class="card shadow-sm"><div class="card-header bg-primary text-white"><h5 class="mb-0"><i class="bi bi-plus-circle me-2"></i>New Inquiry</h5></div>
<div class="card-body">
<form method="post">
<div class="row mb-3">
<div class="col-md-6"><label asp-for="Inquiry.CustomerName" class="form-label"></label><input asp-for="Inquiry.CustomerName" class="form-control" /><span asp-validation-for="Inquiry.CustomerName" class="text-danger small"></span></div>
<div class="col-md-3"><label asp-for="Inquiry.Date" class="form-label"></label><input asp-for="Inquiry.Date" class="form-control" type="date" /></div>
<div class="col-md-3"><label asp-for="Inquiry.Status" class="form-label"></label><select asp-for="Inquiry.Status" class="form-select"><option value="Open">Open</option><option value="Quoted">Quoted</option><option value="Closed">Closed</option></select></div>
</div>
<div class="mb-3"><label asp-for="Inquiry.Description" class="form-label"></label><textarea asp-for="Inquiry.Description" class="form-control" rows="3"></textarea><span asp-validation-for="Inquiry.Description" class="text-danger small"></span></div>
<div class="d-flex gap-2"><button type="submit" class="btn btn-primary"><i class="bi bi-save me-1"></i>Save</button><a asp-page="/SD/Index" class="btn btn-outline-secondary"><i class="bi bi-x me-1"></i>Cancel</a></div>
</form>
</div></div>
</div></div>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }
