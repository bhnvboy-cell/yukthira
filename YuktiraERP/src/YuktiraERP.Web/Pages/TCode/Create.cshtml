@page
@model YuktiraERP.Web.Pages.TCode.CreateModel
@{
    ViewData["Title"] = "New " + Model.Code;
}
<div class="d-flex justify-content-between align-items-center mb-3">
    <h2><i class="bi bi-plus-circle me-2"></i>New @Model.Code</h2>
    <a href="/TCode/List?tcodeId=@Model.TCodeId&code=@Model.Code" class="btn btn-outline-secondary btn-sm"><i class="bi bi-arrow-left"></i> Back</a>
</div>
<div class="card shadow-sm">
    <div class="card-body">
        <div id="formContainer">
            <p class="text-muted">Loading form fields...</p>
        </div>
        <button class="btn btn-primary mt-3" onclick="submitForm()"><i class="bi bi-check"></i> Create</button>
    </div>
</div>

<script>
    var params = new URLSearchParams(location.search);
    var tcodeId = params.get('tcodeId');
    var code = params.get('code');

    async function loadForm() {
        var res = await fetch('/api/tcode-generator/definitions/' + tcodeId + '/fields');
        var fields = await res.json();
        var html = '<div class="row">';
        fields.forEach(function(f) {
            html += '<div class="col-md-' + (f.width > 300 ? '6' : '4') + ' mb-3">';
            html += '<label class="form-label">' + f.fieldLabel + (f.isRequired ? ' <span class="text-danger">*</span>' : '') + '</label>';
            if (f.dataType === 'TEXTAREA') html += '<textarea id="f_' + f.fieldName + '" class="form-control" rows="3"></textarea>';
            else if (f.dataType === 'BOOLEAN') html += '<input id="f_' + f.fieldName + '" type="checkbox" class="form-check-input" style="margin-left:4px" />';
            else if (f.dataType === 'DATE') html += '<input id="f_' + f.fieldName + '" type="date" class="form-control" />';
            else if (f.dataType === 'DATETIME') html += '<input id="f_' + f.fieldName + '" type="datetime-local" class="form-control" />';
            else if (f.dataType === 'NUMBER' || f.dataType === 'DECIMAL') html += '<input id="f_' + f.fieldName + '" type="number" step="0.01" class="form-control" />';
            else html += '<input id="f_' + f.fieldName + '" type="text" class="form-control" value="' + f.defaultValue + '" />';
            html += '</div>';
        });
        html += '</div>';
        document.getElementById('formContainer').innerHTML = html;
    }

    async function submitForm() {
        var res = await fetch('/api/tcode-generator/definitions/' + tcodeId + '/fields');
        var fields = await res.json();
        var data = {};
        fields.forEach(function(f) {
            var el = document.getElementById('f_' + f.fieldName);
            if (el) {
                if (f.dataType === 'BOOLEAN') data[f.fieldName] = el.checked;
                else if (f.dataType === 'NUMBER' || f.dataType === 'DECIMAL') data[f.fieldName] = parseFloat(el.value) || 0;
                else data[f.fieldName] = el.value;
            }
        });
        var createRes = await fetch('/api/tcode-generator/data/' + tcodeId, {
            method: 'POST',
            headers: {'Content-Type': 'application/json'},
            body: JSON.stringify(data)
        });
        if (createRes.ok) {
            location.href = '/TCode/List?tcodeId=' + tcodeId + '&code=' + code;
        } else {
            alert('Failed to create record');
        }
    }

    loadForm();
</script>
