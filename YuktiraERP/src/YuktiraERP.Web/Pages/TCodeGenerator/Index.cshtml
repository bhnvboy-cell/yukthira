@page
@model YuktiraERP.Web.Pages.TCodeGenerator.IndexModel
@{
    ViewData["Title"] = "T-Code Generator";
}
<div class="d-flex justify-content-between align-items-center mb-3">
    <h2><i class="bi bi-cpu me-2"></i>T-Code Generator</h2>
    <button class="btn btn-primary btn-sm" onclick="showCreateModal()"><i class="bi bi-plus"></i> New T-Code</button>
</div>
<div class="card shadow-sm">
    <div class="card-body">
        <table class="table table-hover table-sm">
            <thead><tr><th>Code</th><th>Name</th><th>Module</th><th>Fields</th><th>Workflow</th><th>Number Range</th><th>Status</th><th>Actions</th></tr></thead>
            <tbody id="tcodeTableBody">
                <tr><td colspan="8" class="text-muted text-center">Loading...</td></tr>
            </tbody>
        </table>
    </div>
</div>

<div class="modal fade" id="createModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header"><h5 class="modal-title">Create New T-Code</h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
            <div class="modal-body">
                <div class="mb-3"><label class="form-label">Code</label><input id="newCode" class="form-control" placeholder="e.g. MM-MAT-EXT" /></div>
                <div class="mb-3"><label class="form-label">Name</label><input id="newName" class="form-control" placeholder="Material Extension" /></div>
                <div class="mb-3"><label class="form-label">Module</label>
                    <select id="newModule" class="form-select">
                        <option value="MM">MM - Materials</option>
                        <option value="SD">SD - Sales</option>
                        <option value="PP">PP - Production</option>
                        <option value="QM">QM - Quality</option>
                        <option value="WM">WM - Warehouse</option>
                        <option value="FI">FI - Finance</option>
                        <option value="HR">HR</option>
                        <option value="CRM">CRM</option>
                    </select>
                </div>
                <div class="mb-3"><label class="form-label">Description</label><textarea id="newDesc" class="form-control" rows="2"></textarea></div>
            </div>
            <div class="modal-footer">
                <button class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Cancel</button>
                <button class="btn btn-primary btn-sm" onclick="createTCode()">Create</button>
            </div>
        </div>
    </div>
</div>

<script>
    async function loadTCodes() {
        var res = await fetch('/api/tcode-generator/definitions');
        var data = await res.json();
        var html = '';
        data.forEach(function(d) {
            html += '<tr>' +
                '<td><strong>' + d.code + '</strong></td>' +
                '<td>' + d.name + '</td>' +
                '<td>' + d.module + '</td>' +
                '<td>' + d.fields.length + '</td>' +
                '<td>' + (d.hasWorkflow ? '<span class="badge bg-success">Yes</span>' : '<span class="badge bg-secondary">No</span>') + '</td>' +
                '<td>' + (d.hasNumberRange ? '<span class="badge bg-success">' + d.prefix + '</span>' : '<span class="badge bg-secondary">-</span>') + '</td>' +
                '<td><span class="badge bg-success">' + d.status + '</span></td>' +
                '<td>' +
                '  <a href="/TCodeGenerator/Designer?id=' + d.id + '" class="btn btn-outline-primary btn-sm"><i class="bi bi-gear"></i></a> ' +
                '  <a href="/TCode/List?tcodeId=' + d.id + '&code=' + d.code + '" class="btn btn-outline-primary btn-sm"><i class="bi bi-list"></i></a> ' +
                '  <button class="btn btn-outline-danger btn-sm" onclick="deleteTCode(\'' + d.id + '\')"><i class="bi bi-trash"></i></button>' +
                '</td></tr>';
        });
        document.getElementById('tcodeTableBody').innerHTML = html || '<tr><td colspan="8" class="text-muted text-center">No T-Codes created yet</td></tr>';
    }

    function showCreateModal() { new bootstrap.Modal(document.getElementById('createModal')).show(); }

    async function createTCode() {
        var res = await fetch('/api/tcode-generator/definitions', {
            method: 'POST',
            headers: {'Content-Type': 'application/json'},
            body: JSON.stringify({
                code: document.getElementById('newCode').value,
                name: document.getElementById('newName').value,
                module: document.getElementById('newModule').value,
                description: document.getElementById('newDesc').value
            })
        });
        if (res.ok) {
            bootstrap.Modal.getInstance(document.getElementById('createModal')).hide();
            loadTCodes();
        } else {
            alert('Failed to create T-Code');
        }
    }

    async function deleteTCode(id) {
        if (!confirm('Delete this T-Code definition?')) return;
        var res = await fetch('/api/tcode-generator/definitions/' + id, { method: 'DELETE' });
        if (res.ok) loadTCodes();
    }

    loadTCodes();
</script>
