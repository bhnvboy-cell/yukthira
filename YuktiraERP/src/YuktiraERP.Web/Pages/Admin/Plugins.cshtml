@page
@{
    ViewData["Title"] = "Plugins";
}
<h2><i class="bi bi-puzzle me-2"></i>Plugin Manager</h2>
<div class="card mt-3">
    <div class="card-body">
        <table class="table table-hover">
            <thead><tr><th>Name</th><th>Code</th><th>Version</th><th>Global</th><th>Tenant</th><th>Actions</th></tr></thead>
            <tbody>
                <tr><td>Dairy Extension</td><td>DAIRY_EXT</td><td>1.0.0</td><td><span class="badge bg-success">Enabled</span></td><td><span class="badge bg-success">Enabled</span></td><td><button class="btn btn-sm btn-outline-danger">Disable</button></td></tr>
                <tr><td>Advanced QC</td><td>ADV_QC</td><td>1.0.0</td><td><span class="badge bg-success">Enabled</span></td><td><span class="badge bg-success">Enabled</span></td><td><button class="btn btn-sm btn-outline-danger">Disable</button></td></tr>
                <tr><td>Extra Reports</td><td>EXTRA_REPORTS</td><td>1.0.0</td><td><span class="badge bg-success">Enabled</span></td><td><span class="badge bg-warning">Disabled</span></td><td><button class="btn btn-sm btn-outline-success">Enable</button></td></tr>
            </tbody>
        </table>
    </div>
</div>
