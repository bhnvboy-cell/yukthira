@page
@using YuktiraERP.Web.Models
@{
    ViewData["Title"] = "User Management";
    var users = AdminUserStore.GetAll();
}
<div class="d-flex justify-content-between align-items-center mb-3">
    <h2><i class="bi bi-people me-2"></i>User Management</h2>
    <a asp-page="/Admin/Users" class="btn btn-primary btn-sm"><i class="bi bi-plus"></i> New User</a>
</div>
<div class="card"><div class="card-body">
<table class="table table-hover table-sm">
<thead><tr><th>User ID</th><th>Username</th><th>Email</th><th>Role</th><th>Active</th><th>Created</th><th>Actions</th></tr></thead>
<tbody>
@foreach (var u in users)
{
    <tr>
        <td>@u.UserId</td><td>@u.UserName</td><td>@u.Email</td>
        <td><span class="badge @(u.Role=="SUPER_USER"?"bg-danger":u.Role=="POWER_USER"?"bg-warning":"bg-secondary")">@u.Role</span></td>
        <td>@if(u.IsActive){<i class="bi bi-check-circle text-success"></i>}else{<i class="bi bi-x-circle text-danger"></i>}</td>
        <td>@u.CreatedAt.ToString("d")</td>
        <td><i class="bi bi-pencil me-2"></i><i class="bi bi-trash text-danger"></i></td>
    </tr>
}
</tbody>
</table>
</div></div>
