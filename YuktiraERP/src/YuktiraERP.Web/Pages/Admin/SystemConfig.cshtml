@page
@using YuktiraERP.Web.Models
@{
    ViewData["Title"] = "System Configuration";
    var configs = SystemConfigStore.GetAll();
    var groups = configs.GroupBy(c => c.Module);
}
<h2><i class="bi bi-sliders me-2"></i>System Configuration</h2>
@foreach (var group in groups)
{
<div class="card mt-3"><div class="card-header"><h5 class="mb-0">@group.Key</h5></div><div class="card-body">
<table class="table table-sm table-borderless mb-0">
<tbody>
@foreach (var c in group)
{
    <tr><td style="width:250px"><code>@c.Key</code></td><td><input class="form-control form-control-sm" value="@c.Value" /></td><td><small class="text-muted">@c.Description</small></td></tr>
}
</tbody>
</table>
</div></div>
}
<div class="mt-3"><button class="btn btn-primary"><i class="bi bi-save me-1"></i>Save All</button></div>
