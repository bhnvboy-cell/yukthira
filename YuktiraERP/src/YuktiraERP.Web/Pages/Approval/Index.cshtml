@page
@using YuktiraERP.Web.Models
@{
    ViewData["Title"] = "Approvals";
    var pending = ApprovalRequestStore.GetAll().Where(a => a.Status == "Pending").ToList();
    var approved = ApprovalRequestStore.GetAll().Where(a => a.Status == "Approved").ToList();
    var rejected = ApprovalRequestStore.GetAll().Where(a => a.Status == "Rejected").ToList();
    var all = ApprovalRequestStore.GetAll();
}
<div class="d-flex justify-content-between align-items-center mb-3">
    <h2><i class="bi bi-check2-square me-2"></i>Approvals</h2>
    <div><a asp-page="/Approval/Create" class="btn btn-primary btn-sm"><i class="bi bi-plus"></i> New Request</a></div>
</div>
<ul class="nav nav-tabs mb-3">
    <li class="nav-item"><a class="nav-link active" data-bs-toggle="tab" href="#pending">Pending (@pending.Count)</a></li>
    <li class="nav-item"><a class="nav-link" data-bs-toggle="tab" href="#approved">Approved (@approved.Count)</a></li>
    <li class="nav-item"><a class="nav-link" data-bs-toggle="tab" href="#rejected">Rejected (@rejected.Count)</a></li>
    <li class="nav-item"><a class="nav-link" data-bs-toggle="tab" href="#my">All Requests</a></li>
</ul>
<div class="tab-content">
    <div class="tab-pane fade show active" id="pending">
        <div class="card"><div class="card-body">
            <table class="table table-hover table-sm">
                <thead><tr><th>Request ID</th><th>Type</th><th>Subject</th><th>Requestor</th><th>Date</th><th>Amount</th><th>Actions</th></tr></thead>
                <tbody>
                    @foreach (var a in pending)
                    {
                        <tr>
                            <td>@a.RequestId</td><td>@a.Type</td><td>@a.Subject</td><td>@a.Requestor</td><td>@a.RequestDate.ToString("d")</td>
                            <td>@(a.Amount.HasValue ? a.Amount.Value.ToString("C2") : "--")</td>
                            <td>
                                <form method="post" asp-page-handler="Approve" asp-route-id="@a.RequestId" style="display:inline">
                                    <button type="submit" class="btn btn-success btn-sm"><i class="bi bi-check"></i></button>
                                </form>
                                <form method="post" asp-page-handler="Reject" asp-route-id="@a.RequestId" style="display:inline">
                                    <button type="submit" class="btn btn-danger btn-sm"><i class="bi bi-x"></i></button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div></div>
    </div>
    <div class="tab-pane fade" id="approved">
        <div class="card"><div class="card-body">
            <table class="table table-hover table-sm">
                <thead><tr><th>Request ID</th><th>Subject</th><th>Requestor</th><th>Amount</th></tr></thead>
                <tbody>
                    @foreach (var a in approved) { <tr><td>@a.RequestId</td><td>@a.Subject</td><td>@a.Requestor</td><td>@(a.Amount?.ToString("C2") ?? "--")</td></tr> }
                </tbody>
            </table>
        </div></div>
    </div>
    <div class="tab-pane fade" id="rejected">
        <div class="card"><div class="card-body">
            <table class="table table-hover table-sm">
                <thead><tr><th>Request ID</th><th>Subject</th><th>Requestor</th><th>Amount</th></tr></thead>
                <tbody>
                    @foreach (var a in rejected) { <tr><td>@a.RequestId</td><td>@a.Subject</td><td>@a.Requestor</td><td>@(a.Amount?.ToString("C2") ?? "--")</td></tr> }
                </tbody>
            </table>
        </div></div>
    </div>
    <div class="tab-pane fade" id="my">
        <div class="card"><div class="card-body">
            <table class="table table-hover table-sm">
                <thead><tr><th>Request ID</th><th>Type</th><th>Subject</th><th>Status</th></tr></thead>
                <tbody>
                    @foreach (var a in all) { <tr><td>@a.RequestId</td><td>@a.Type</td><td>@a.Subject</td><td><span class="badge @(a.Status=="Approved"?"bg-success":a.Status=="Rejected"?"bg-danger":"bg-info")">@a.Status</span></td></tr> }
                </tbody>
            </table>
        </div></div>
    </div>
</div>
