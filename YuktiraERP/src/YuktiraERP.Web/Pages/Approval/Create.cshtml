@page
@model YuktiraERP.Web.Pages.Approval.CreateModel
@{ ViewData["Title"] = "New Approval Request"; }
<div class="row justify-content-center"><div class="col-lg-8">
    <div class="card shadow-sm"><div class="card-header bg-primary text-white"><h5 class="mb-0"><i class="bi bi-plus-circle me-2"></i>New Approval Request</h5></div>
    <div class="card-body">
        <form method="post">
            <div class="row mb-3">
                <div class="col-md-4"><label asp-for="ApprovalRequest.Type" class="form-label"></label><select asp-for="ApprovalRequest.Type" class="form-select"><option>Purchase Order</option><option>Leave</option><option>Capital Expense</option><option>Invoice</option><option>Travel</option></select></div>
                <div class="col-md-4"><label asp-for="ApprovalRequest.Requestor" class="form-label"></label><input asp-for="ApprovalRequest.Requestor" class="form-control" /></div>
                <div class="col-md-4"><label asp-for="ApprovalRequest.Amount" class="form-label"></label><input asp-for="ApprovalRequest.Amount" class="form-control" /></div>
            </div>
            <div class="mb-3"><label asp-for="ApprovalRequest.Subject" class="form-label"></label><input asp-for="ApprovalRequest.Subject" class="form-control" /></div>
            <div class="d-flex gap-2"><button type="submit" class="btn btn-primary"><i class="bi bi-save me-1"></i>Submit</button><a asp-page="/Approval/Index" class="btn btn-outline-secondary">Cancel</a></div>
        </form>
    </div></div>
</div></div>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }
