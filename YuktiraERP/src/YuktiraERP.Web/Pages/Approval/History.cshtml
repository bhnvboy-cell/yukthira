@page
@model YuktiraERP.Web.Pages.Approval.PendingModel
@using YuktiraERP.Infrastructure.Data.Entities
@{ ViewData["Title"] = "Approval History (AP02)"; }
<h2><i class="bi bi-clock me-2"></i>Approval History</h2>
<div class="card mt-3"><div class="card-body">
<table class="table table-hover table-sm datatable">
<thead><tr><th>Request ID</th><th>Type</th><th>Subject</th><th>Requestor</th><th>Date</th><th>Amount</th><th>Status</th></tr></thead>
<tbody>
@foreach (var a in Model.Items)
{
<tr>
<td>@a.RequestId</td><td>@a.Type</td><td>@a.Subject</td><td>@a.Requestor</td><td>@a.RequestDate.ToString("d")</td>
<td>@(a.Amount?.ToString("C2") ?? "-")</td>
<td><span class="badge bg-secondary">@a.Status</span></td>
</tr>
}
</tbody></table>
</div></div></div>
