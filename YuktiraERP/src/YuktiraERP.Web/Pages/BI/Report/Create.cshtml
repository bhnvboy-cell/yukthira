@page
@model YuktiraERP.Web.Pages.BI.Report.CreateModel
@{ ViewData["Title"] = "Create Report"; }
<div class="row justify-content-center"><div class="col-lg-8">
<div class="card shadow-sm"><div class="card-header bg-primary text-white"><h5 class="mb-0"><i class="bi bi-plus-circle me-2"></i>Create BI Report</h5></div>
<div class="card-body">
<form method="post">
<div class="row mb-3">
<div class="col-md-6"><label asp-for="Report.ReportName" class="form-label"></label><input asp-for="Report.ReportName" class="form-control" /></div>
<div class="col-md-3"><label asp-for="Report.Category" class="form-label"></label><select asp-for="Report.Category" class="form-select"><option>Sales</option><option>Inventory</option><option>Production</option><option>Finance</option><option>Quality</option><option>HR</option></select></div>
<div class="col-md-3"><label asp-for="Report.Format" class="form-label"></label><select asp-for="Report.Format" class="form-select"><option>PDF</option><option>Excel</option><option>HTML</option><option>CSV</option></select></div>
</div>
<div class="d-flex gap-2"><button type="submit" class="btn btn-primary"><i class="bi bi-save me-1"></i>Save</button><a asp-page="/BI/Index" class="btn btn-outline-secondary">Cancel</a></div>
</form>
</div></div>
</div></div>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }
