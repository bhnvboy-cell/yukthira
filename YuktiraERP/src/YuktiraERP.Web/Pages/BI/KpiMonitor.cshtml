@page
@model YuktiraERP.Web.Pages.BI.KpiMonitorModel
@{ ViewData["Title"] = "KPI Monitor (BI04)"; }
<h2><i class="bi bi-speedometer2 me-2"></i>KPI Monitor</h2>
<div class="row mt-3">
@foreach (var k in Model.Kpis)
{
<div class="col-md-4 mb-3">
<div class="card text-center"><div class="card-body">
<h6 class="card-title text-muted">@k.Key</h6>
<h3 class="text-primary">@k.Value</h3>
</div></div>
</div>
}
</div>
