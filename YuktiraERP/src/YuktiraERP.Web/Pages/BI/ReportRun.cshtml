@page
@model YuktiraERP.Web.Pages.BI.ReportRunModel
@using YuktiraERP.Infrastructure.Data.Entities
@{ ViewData["Title"] = "Report Run (BI02)"; }
<h2><i class="bi bi-file-earmark-bar-graph me-2"></i>Run Report</h2>
<form method="post" asp-page-handler="Run" class="row g-3 mb-3">
<div class="col-auto"><select name="ReportId" class="form-select">
<option value="">-- Select Report --</option>
@foreach (var r in Model.Reports) { <option value="@r.ReportId">@r.ReportName</option> }
</select></div>
<div class="col-auto"><button type="submit" class="btn btn-primary"><i class="bi bi-play me-1"></i>Run</button></div>
</form>
@if (!string.IsNullOrEmpty(Model.ResultHtml)) { @Html.Raw(Model.ResultHtml) }
<div class="card"><div class="card-body">
<table class="table table-hover table-sm">
<thead><tr><th>Report ID</th><th>Name</th><th>Category</th><th>Format</th><th>Last Run</th></tr></thead>
<tbody>
@foreach (var r in Model.Reports) { <tr><td>@r.ReportId</td><td>@r.ReportName</td><td>@r.Category</td><td>@r.Format</td><td>@r.LastRun.ToString("g")</td></tr> }
</tbody></table>
</div></div></div>
