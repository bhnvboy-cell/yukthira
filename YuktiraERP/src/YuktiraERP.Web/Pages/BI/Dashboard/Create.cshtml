@page
@model YuktiraERP.Web.Pages.BI.Dashboard.CreateModel
@{ ViewData["Title"] = "New Dashboard"; }
<div class="row justify-content-center"><div class="col-lg-8">
<div class="card shadow-sm"><div class="card-header bg-primary text-white"><h5 class="mb-0"><i class="bi bi-plus-circle me-2"></i>New Dashboard</h5></div>
<div class="card-body">
<form method="post">
<div class="row mb-3">
<div class="col-md-6"><label asp-for="Dashboard.Name" class="form-label"></label><input asp-for="Dashboard.Name" class="form-control" /><span asp-validation-for="Dashboard.Name" class="text-danger small"></span></div>
<div class="col-md-3"><label asp-for="Dashboard.Category" class="form-label"></label><select asp-for="Dashboard.Category" class="form-select"><option value="Executive">Executive</option><option value="Sales">Sales</option><option value="Inventory">Inventory</option><option value="Production">Production</option><option value="Finance">Finance</option></select></div>
<div class="col-md-3"><label asp-for="Dashboard.Status" class="form-label"></label><select asp-for="Dashboard.Status" class="form-select"><option value="Active">Active</option><option value="Inactive">Inactive</option></select></div>
</div>
<div class="d-flex gap-2"><button type="submit" class="btn btn-primary"><i class="bi bi-save me-1"></i>Save</button><a asp-page="/BI/Index" class="btn btn-outline-secondary"><i class="bi bi-x me-1"></i>Cancel</a></div>
</form>
</div></div>
</div></div>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }
