@page
@model YuktiraERP.Web.Pages.WM.StorageLocation.CreateModel
@{ ViewData["Title"] = "New Storage Location"; }
<div class="row justify-content-center"><div class="col-lg-8">
<div class="card shadow-sm"><div class="card-header bg-primary text-white"><h5 class="mb-0"><i class="bi bi-plus-circle me-2"></i>New Storage Location</h5></div>
<div class="card-body">
<form method="post">
<div class="row mb-3">
<div class="col-md-6"><label asp-for="Location.Name" class="form-label"></label><input asp-for="Location.Name" class="form-control" /><span asp-validation-for="Location.Name" class="text-danger small"></span></div>
<div class="col-md-3"><label asp-for="Location.Type" class="form-label"></label><select asp-for="Location.Type" class="form-select"><option value="Warehouse">Warehouse</option><option value="Rack">Rack</option><option value="Cold Storage">Cold Storage</option><option value="Yard">Yard</option></select></div>
<div class="col-md-3"><label asp-for="Location.Status" class="form-label"></label><select asp-for="Location.Status" class="form-select"><option value="Active">Active</option><option value="Full">Full</option><option value="Inactive">Inactive</option></select></div>
</div>
<div class="row mb-4">
<div class="col-md-4"><label asp-for="Location.Capacity" class="form-label"></label><input asp-for="Location.Capacity" class="form-control" min="0" step="1" /><span asp-validation-for="Location.Capacity" class="text-danger small"></span></div>
</div>
<div class="d-flex gap-2"><button type="submit" class="btn btn-primary"><i class="bi bi-save me-1"></i>Save</button><a asp-page="/WM/Index" class="btn btn-outline-secondary"><i class="bi bi-x me-1"></i>Cancel</a></div>
</form>
</div></div>
</div></div>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }
