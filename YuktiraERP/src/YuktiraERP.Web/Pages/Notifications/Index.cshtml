@page
@model YuktiraERP.Web.Pages.Notifications.IndexModel
@{
    ViewData["Title"] = "Notifications";
}
<h2><i class="bi bi-bell me-2"></i>Notifications</h2>
<div class="mt-3">
    @if (Model.Notifications.Any(n => !n.IsRead))
    {
        <button class="btn btn-outline-primary btn-sm mb-3" onclick="markAllRead()"><i class="bi bi-check-all"></i> Mark All as Read</button>
    }
    @if (Model.Notifications.Count == 0)
    {
        <div class="text-center py-5 text-muted">
            <i class="bi bi-bell" style="font-size:3rem"></i>
            <p class="mt-2 mb-0">No notifications yet</p>
            <small>Notifications from system events will appear here</small>
        </div>
    }
    <div class="list-group">
        @foreach (var n in Model.Notifications)
        {
            <div class="list-group-item list-group-item-action @(!n.IsRead ? "list-group-item-primary" : "")">
                <div class="d-flex w-100 justify-content-between">
                    <h6 class="mb-1">@n.Title</h6>
                    <small class="text-muted">@n.CreatedAt.ToString("g")</small>
                </div>
                <p class="mb-1">@n.Message</p>
                @if (!n.IsRead)
                {
                    <button class="btn btn-sm btn-outline-secondary" onclick="markRead('@n.Id')">Mark Read</button>
                }
            </div>
        }
    </div>
</div>
@section Scripts {
<script>
    function markRead(id) {
        fetch('/api/notifications/' + id + '/read', { method: 'PUT' }).then(function() { location.reload(); });
    }
    function markAllRead() {
        fetch('/api/notifications/read-all', { method: 'PUT' }).then(function() { location.reload(); });
    }
</script>
}
