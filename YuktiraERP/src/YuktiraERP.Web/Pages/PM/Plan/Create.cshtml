@page
@model YuktiraERP.Web.Pages.PM.Plan.CreateModel
@{ ViewData["Title"] = "Create Maintenance Plan"; }
<div class="row justify-content-center"><div class="col-lg-8">
    <div class="card shadow-sm"><div class="card-header bg-primary text-white"><h5 class="mb-0"><i class="bi bi-plus-circle me-2"></i>Create Maintenance Plan</h5></div>
    <div class="card-body">
        <form method="post">
            <div class="row mb-3">
                <div class="col-md-4"><label asp-for="Plan.PlanCode" class="form-label"></label><input asp-for="Plan.PlanCode" class="form-control" placeholder="MP-001" /></div>
                <div class="col-md-4"><label asp-for="Plan.Name" class="form-label"></label><input asp-for="Plan.Name" class="form-control" /></div>
                <div class="col-md-4"><label asp-for="Plan.EquipmentCode" class="form-label"></label><input asp-for="Plan.EquipmentCode" class="form-control" placeholder="EQ-001" /></div>
            </div>
            <div class="row mb-3">
                <div class="col-md-4"><label asp-for="Plan.Frequency" class="form-label"></label><select asp-for="Plan.Frequency" class="form-select"><option>Daily</option><option>Weekly</option><option>Monthly</option><option>Quarterly</option><option>Yearly</option></select></div>
                <div class="col-md-4"><label asp-for="Plan.EstimatedHours" class="form-label"></label><input asp-for="Plan.EstimatedHours" class="form-control" type="number" step="0.5" /></div>
            </div>
            <div class="row mb-3">
                <div class="col-md-12"><label asp-for="Plan.TaskDescription" class="form-label"></label><textarea asp-for="Plan.TaskDescription" class="form-control" rows="2"></textarea></div>
            </div>
            <div class="d-flex gap-2"><button type="submit" class="btn btn-primary"><i class="bi bi-save me-1"></i>Save</button><a asp-page="/PM/Index" class="btn btn-outline-secondary">Cancel</a></div>
        </form>
    </div></div>
</div></div>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }
