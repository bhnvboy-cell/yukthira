@page
@model YuktiraERP.Web.Pages.PM.Equipment.CreateModel
@{ ViewData["Title"] = "Create Equipment"; }
<div class="row justify-content-center"><div class="col-lg-8">
    <div class="card shadow-sm"><div class="card-header bg-primary text-white"><h5 class="mb-0"><i class="bi bi-plus-circle me-2"></i>Create Equipment</h5></div>
    <div class="card-body">
        <form method="post">
            <div class="row mb-3">
                <div class="col-md-4"><label asp-for="Equipment.EquipmentCode" class="form-label"></label><input asp-for="Equipment.EquipmentCode" class="form-control" placeholder="EQ-001" /></div>
                <div class="col-md-4"><label asp-for="Equipment.Name" class="form-label"></label><input asp-for="Equipment.Name" class="form-control" /></div>
                <div class="col-md-4"><label asp-for="Equipment.Type" class="form-label"></label><select asp-for="Equipment.Type" class="form-select"><option>Machine</option><option>Vehicle</option><option>Instrument</option><option>Building</option></select></div>
            </div>
            <div class="row mb-3">
                <div class="col-md-4"><label asp-for="Equipment.Location" class="form-label"></label><input asp-for="Equipment.Location" class="form-control" /></div>
                <div class="col-md-4"><label asp-for="Equipment.Department" class="form-label"></label><input asp-for="Equipment.Department" class="form-control" /></div>
            </div>
            <div class="d-flex gap-2"><button type="submit" class="btn btn-primary"><i class="bi bi-save me-1"></i>Save</button><a asp-page="/PM/Index" class="btn btn-outline-secondary">Cancel</a></div>
        </form>
    </div></div>
</div></div>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }
