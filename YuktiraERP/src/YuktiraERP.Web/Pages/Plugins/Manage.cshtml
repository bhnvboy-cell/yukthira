@page
@model YuktiraERP.Web.Pages.Plugins.ManageModel
@{ ViewData["Title"] = "Plugins (PL01)"; }
<h2><i class="bi bi-puzzle me-2"></i>Plugins</h2>
<div class="card mt-3"><div class="card-body">
<table class="table table-hover table-sm">
<thead><tr><th>Name</th><th>Version</th><th>Status</th></tr></thead>
<tbody>
@foreach (var p in Model.Plugins)
{
<tr>
<td>@p.Name</td><td>@p.Version</td>
<td><span class="badge bg-@(p.Status=="Active"?"success":"secondary")">@p.Status</span></td>
</tr>
}
</tbody></table>
</div></div></div>
