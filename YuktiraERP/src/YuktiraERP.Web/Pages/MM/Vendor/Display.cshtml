@page
@model YuktiraERP.Web.Pages.MM.Vendor.DisplayModel
@using YuktiraERP.Infrastructure.Data.Entities
@{ ViewData["Title"] = "Vendor Details"; }
<div class="row justify-content-center"><div class="col-lg-8">
<div class="card shadow-sm"><div class="card-header bg-info text-white"><h5 class="mb-0"><i class="bi bi-eye me-2"></i>Vendor Details</h5></div>
<div class="card-body">
<dl class="row mb-0">
<dt class="col-sm-4">Code</dt><dd class="col-sm-8">@Model.Vendor.Code</dd>
<dt class="col-sm-4">Name</dt><dd class="col-sm-8">@Model.Vendor.Name</dd>
<dt class="col-sm-4">TaxId</dt><dd class="col-sm-8">@Model.Vendor.TaxId</dd>
<dt class="col-sm-4">PaymentTerms</dt><dd class="col-sm-8">@Model.Vendor.PaymentTerms</dd>
<dt class="col-sm-4">Phone</dt><dd class="col-sm-8">@Model.Vendor.Phone</dd>
<dt class="col-sm-4">Status</dt><dd class="col-sm-8">@Model.Vendor.Status</dd>
</dl>
</div>
<div class="card-footer">
<a asp-page="/MM/Index" class="btn btn-outline-secondary"><i class="bi bi-arrow-left me-1"></i>Back</a>
<a asp-page="/MM/Vendor/Edit" asp-route-id="@Model.Vendor.Id" class="btn btn-warning"><i class="bi bi-pencil me-1"></i>Edit</a>
</div>
</div></div>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }
