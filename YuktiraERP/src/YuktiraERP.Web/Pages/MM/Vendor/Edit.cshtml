@page
@model YuktiraERP.Web.Pages.MM.Vendor.EditModel
@{ ViewData["Title"] = "Edit Vendor"; }
<div class="row justify-content-center"><div class="col-lg-8">
<div class="card shadow-sm"><div class="card-header bg-warning text-dark"><h5 class="mb-0"><i class="bi bi-pencil me-2"></i>Edit Vendor</h5></div>
<div class="card-body">
<form method="post">
<input type="hidden" asp-for="Vendor.Id" />
<div class="row mb-3">
<div class="col-md-6"><label asp-for="Vendor.Code" class="form-label"></label><input asp-for="Vendor.Code" class="form-control" /><span asp-validation-for="Vendor.Code" class="text-danger small"></span></div>
<div class="col-md-6"><label asp-for="Vendor.Name" class="form-label"></label><input asp-for="Vendor.Name" class="form-control" /><span asp-validation-for="Vendor.Name" class="text-danger small"></span></div>
</div>
<div class="row mb-3">
<div class="col-md-6"><label asp-for="Vendor.TaxId" class="form-label"></label><input asp-for="Vendor.TaxId" class="form-control" /><span asp-validation-for="Vendor.TaxId" class="text-danger small"></span></div>
<div class="col-md-6"><label asp-for="Vendor.PaymentTerms" class="form-label"></label><input asp-for="Vendor.PaymentTerms" class="form-control" /><span asp-validation-for="Vendor.PaymentTerms" class="text-danger small"></span></div>
</div>
<div class="row mb-3">
<div class="col-md-6"><label asp-for="Vendor.Phone" class="form-label"></label><input asp-for="Vendor.Phone" class="form-control" /><span asp-validation-for="Vendor.Phone" class="text-danger small"></span></div>
<div class="col-md-6"><label asp-for="Vendor.Status" class="form-label"></label><input asp-for="Vendor.Status" class="form-control" /><span asp-validation-for="Vendor.Status" class="text-danger small"></span></div>
</div>
<div class="d-flex gap-2"><button type="submit" class="btn btn-warning"><i class="bi bi-save me-1"></i>Update</button><a asp-page="/MM/Index" class="btn btn-outline-secondary"><i class="bi bi-x me-1"></i>Cancel</a></div>
</form>
</div></div>
</div></div>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }
