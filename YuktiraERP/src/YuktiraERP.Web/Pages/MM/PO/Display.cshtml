@page
@model YuktiraERP.Web.Pages.MM.PO.DisplayModel
@using YuktiraERP.Infrastructure.Data.Entities
@{ ViewData["Title"] = "Purchase Order Details"; }
<div class="row justify-content-center"><div class="col-lg-8">
<div class="card shadow-sm"><div class="card-header bg-info text-white"><h5 class="mb-0"><i class="bi bi-eye me-2"></i>Purchase Order Details</h5></div>
<div class="card-body">
<dl class="row mb-0">
<dt class="col-sm-4">PoNumber</dt><dd class="col-sm-8">@Model.Order.PoNumber</dd>
<dt class="col-sm-4">Date</dt><dd class="col-sm-8">@Model.Order.Date</dd>
<dt class="col-sm-4">VendorName</dt><dd class="col-sm-8">@Model.Order.VendorName</dd>
<dt class="col-sm-4">ItemName</dt><dd class="col-sm-8">@Model.Order.ItemName</dd>
<dt class="col-sm-4">Quantity</dt><dd class="col-sm-8">@Model.Order.Quantity</dd>
<dt class="col-sm-4">Amount</dt><dd class="col-sm-8">@Model.Order.Amount</dd>
<dt class="col-sm-4">Status</dt><dd class="col-sm-8">@Model.Order.Status</dd>
</dl>
</div>
<div class="card-footer">
<a asp-page="/MM/Index" class="btn btn-outline-secondary"><i class="bi bi-arrow-left me-1"></i>Back</a>
<a asp-page="/MM/PO/Edit" asp-route-id="@Model.Order.Id" class="btn btn-warning"><i class="bi bi-pencil me-1"></i>Edit</a>
</div>
</div></div>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }
