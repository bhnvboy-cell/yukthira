@page
@model YuktiraERP.Web.Pages.MM.Material.CreateModel
@{ ViewData["Title"] = "Create Material Master"; }
<div class="row justify-content-center"><div class="col-lg-8">
<div class="card shadow-sm"><div class="card-header bg-primary text-white"><h5 class="mb-0"><i class="bi bi-plus-circle me-2"></i>Create Material Master</h5></div>
<div class="card-body">
<form method="post">
<div class="row mb-3">
<div class="col-md-4"><label asp-for="Material.Code" class="form-label"></label><input asp-for="Material.Code" class="form-control" placeholder="e.g. FG-002" /><span asp-validation-for="Material.Code" class="text-danger small"></span></div>
<div class="col-md-8"><label asp-for="Material.Name" class="form-label"></label><input asp-for="Material.Name" class="form-control" placeholder="Material description" /><span asp-validation-for="Material.Name" class="text-danger small"></span></div>
</div>
<div class="row mb-3">
<div class="col-md-4"><label asp-for="Material.Type" class="form-label"></label><select asp-for="Material.Type" class="form-select"><option value="RAW">Raw Material</option><option value="FINISHED">Finished Good</option><option value="WIP">Work In Progress</option><option value="PACKAGING">Packaging</option><option value="CONSUMABLE">Consumable</option></select></div>
<div class="col-md-3"><label asp-for="Material.UOM" class="form-label"></label><select asp-for="Material.UOM" class="form-select"><option value="EA">Each</option><option value="KG">Kilogram</option><option value="LB">Pound</option><option value="M">Meter</option><option value="L">Liter</option><option value="BX">Box</option><option value="PAL">Pallet</option></select></div>
<div class="col-md-3"><label asp-for="Material.Stock" class="form-label"></label><input asp-for="Material.Stock" class="form-control" min="0" step="1" /><span asp-validation-for="Material.Stock" class="text-danger small"></span></div>
<div class="col-md-2"><label asp-for="Material.Price" class="form-label"></label><input asp-for="Material.Price" class="form-control" min="0" step="0.01" /><span asp-validation-for="Material.Price" class="text-danger small"></span></div>
</div>
<div class="row mb-4">
<div class="col-md-4"><label asp-for="Material.Status" class="form-label"></label><select asp-for="Material.Status" class="form-select"><option value="Active">Active</option><option value="Inactive">Inactive</option><option value="Low Stock">Low Stock</option><option value="Discontinued">Discontinued</option></select></div>
</div>
<div class="d-flex gap-2"><button type="submit" class="btn btn-primary"><i class="bi bi-save me-1"></i>Save</button><a asp-page="/MM/Index" class="btn btn-outline-secondary"><i class="bi bi-x me-1"></i>Cancel</a></div>
</form>
</div></div>
</div></div>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }
