@page
@model YuktiraERP.Web.Pages.MM.Material.DisplayModel
@using YuktiraERP.Infrastructure.Data.Entities
@{ ViewData["Title"] = "Material Master Details"; }
<div class="row justify-content-center"><div class="col-lg-8">
<div class="card shadow-sm"><div class="card-header bg-info text-white"><h5 class="mb-0"><i class="bi bi-eye me-2"></i>Material Master Details</h5></div>
<div class="card-body">
<dl class="row mb-0">
<dt class="col-sm-4">Code</dt><dd class="col-sm-8">@Model.Material.Code</dd>
<dt class="col-sm-4">Name</dt><dd class="col-sm-8">@Model.Material.Name</dd>
<dt class="col-sm-4">Type</dt><dd class="col-sm-8">@Model.Material.Type</dd>
<dt class="col-sm-4">UOM</dt><dd class="col-sm-8">@Model.Material.UOM</dd>
<dt class="col-sm-4">Stock</dt><dd class="col-sm-8">@Model.Material.Stock</dd>
<dt class="col-sm-4">Price</dt><dd class="col-sm-8">@Model.Material.Price</dd>
<dt class="col-sm-4">Status</dt><dd class="col-sm-8">@Model.Material.Status</dd>
</dl>
</div>
<div class="card-footer">
<a asp-page="/MM/Index" class="btn btn-outline-secondary"><i class="bi bi-arrow-left me-1"></i>Back</a>
<a asp-page="/MM/Material/Edit" asp-route-id="@Model.Material.Id" class="btn btn-warning"><i class="bi bi-pencil me-1"></i>Edit</a>
</div>
</div></div>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }
