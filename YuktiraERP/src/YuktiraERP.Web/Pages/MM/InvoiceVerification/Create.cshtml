@page
@model YuktiraERP.Web.Pages.MM.InvoiceVerification.CreateModel
@{ ViewData["Title"] = "Invoice Verification"; }
<div class="row justify-content-center"><div class="col-lg-8">
<div class="card shadow-sm"><div class="card-header bg-primary text-white"><h5 class="mb-0"><i class="bi bi-plus-circle me-2"></i>Invoice Verification</h5></div>
<div class="card-body">
<form method="post">
<div class="row mb-3">
<div class="col-md-4"><label asp-for="Invoice.PoNumber" class="form-label"></label><input asp-for="Invoice.PoNumber" class="form-control" placeholder="PO-2024-..." /><span asp-validation-for="Invoice.PoNumber" class="text-danger small"></span></div>
<div class="col-md-4"><label asp-for="Invoice.VendorName" class="form-label"></label><input asp-for="Invoice.VendorName" class="form-control" /><span asp-validation-for="Invoice.VendorName" class="text-danger small"></span></div>
<div class="col-md-4"><label asp-for="Invoice.Date" class="form-label"></label><input asp-for="Invoice.Date" class="form-control" type="date" /></div>
</div>
<div class="row mb-3">
<div class="col-md-4"><label asp-for="Invoice.Amount" class="form-label"></label><input asp-for="Invoice.Amount" class="form-control" min="0" step="0.01" /><span asp-validation-for="Invoice.Amount" class="text-danger small"></span></div>
<div class="col-md-4"><label asp-for="Invoice.MatchedAmount" class="form-label"></label><input asp-for="Invoice.MatchedAmount" class="form-control" min="0" step="0.01" /><span asp-validation-for="Invoice.MatchedAmount" class="text-danger small"></span></div>
<div class="col-md-4"><label asp-for="Invoice.Status" class="form-label"></label><select asp-for="Invoice.Status" class="form-select"><option value="Pending">Pending</option><option value="Matched">Matched</option><option value="Variance">Variance</option></select></div>
</div>
<div class="d-flex gap-2"><button type="submit" class="btn btn-primary"><i class="bi bi-save me-1"></i>Save</button><a asp-page="/MM/Index" class="btn btn-outline-secondary"><i class="bi bi-x me-1"></i>Cancel</a></div>
</form>
</div></div>
</div></div>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }
