@page
@model YuktiraERP.Web.Pages.MM.CreateVendorModel
@{ ViewData["Title"] = "Create Vendor"; }
<div class="row justify-content-center"><div class="col-lg-8">
    <div class="card shadow-sm"><div class="card-header bg-primary text-white"><h5 class="mb-0"><i class="bi bi-plus-circle me-2"></i>Create Vendor</h5></div>
    <div class="card-body">
        <form method="post">
            <div class="row mb-3">
                <div class="col-md-6"><label asp-for="Vendor.Name" class="form-label"></label><input asp-for="Vendor.Name" class="form-control" /></div>
                <div class="col-md-3"><label asp-for="Vendor.Phone" class="form-label"></label><input asp-for="Vendor.Phone" class="form-control" /></div>
                <div class="col-md-3"><label asp-for="Vendor.Status" class="form-label"></label><select asp-for="Vendor.Status" class="form-select"><option>Active</option><option>On Hold</option><option>Inactive</option></select></div>
            </div>
            <div class="row mb-3">
                <div class="col-md-4"><label asp-for="Vendor.TaxId" class="form-label"></label><input asp-for="Vendor.TaxId" class="form-control" /></div>
                <div class="col-md-4"><label asp-for="Vendor.PaymentTerms" class="form-label"></label><select asp-for="Vendor.PaymentTerms" class="form-select"><option>Net 30</option><option>Net 45</option><option>Net 60</option></select></div>
            </div>
            <div class="d-flex gap-2"><button type="submit" class="btn btn-primary"><i class="bi bi-save me-1"></i>Save</button><a asp-page="/MM/Index" class="btn btn-outline-secondary">Cancel</a></div>
        </form>
    </div></div>
</div></div>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }
