@page
@model YuktiraERP.Web.Pages.MM.GRN.CreateModel
@{ ViewData["Title"] = "Create Goods Receipt"; }
<div class="row justify-content-center"><div class="col-lg-8">
<div class="card shadow-sm"><div class="card-header bg-primary text-white"><h5 class="mb-0"><i class="bi bi-plus-circle me-2"></i>Create Goods Receipt Note</h5></div>
<div class="card-body">
<form method="post">
<div class="row mb-3">
<div class="col-md-4"><label asp-for="Receipt.PoNumber" class="form-label"></label><input asp-for="Receipt.PoNumber" class="form-control" placeholder="PO-2024-..." /></div>
<div class="col-md-8"><label asp-for="Receipt.MaterialName" class="form-label"></label><input asp-for="Receipt.MaterialName" class="form-control" /></div>
</div>
<div class="row mb-3">
<div class="col-md-3"><label asp-for="Receipt.QtyReceived" class="form-label"></label><input asp-for="Receipt.QtyReceived" class="form-control" /></div>
<div class="col-md-3"><label asp-for="Receipt.QtyAccepted" class="form-label"></label><input asp-for="Receipt.QtyAccepted" class="form-control" /></div>
<div class="col-md-3"><label asp-for="Receipt.Status" class="form-label"></label><select asp-for="Receipt.Status" class="form-select"><option>Inspection Pending</option><option>Posted</option><option>Returned</option></select></div>
</div>
<div class="d-flex gap-2"><button type="submit" class="btn btn-primary"><i class="bi bi-save me-1"></i>Save</button><a asp-page="/MM/Index" class="btn btn-outline-secondary">Cancel</a></div>
</form>
</div></div>
</div></div>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }
